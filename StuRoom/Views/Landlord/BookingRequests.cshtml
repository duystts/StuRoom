@model List<StuRoom.Models.BookingRequest>
@using StuRoom.Models
@{
    ViewData["Title"] = "Quản lý đặt phòng";
    var currentFilter = ViewData["Filter"]?.ToString() ?? "pending";
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0">Đặt phòng</h4>
    <p class="text-muted small mb-0">Duyệt hoặc từ chối yêu cầu đặt phòng từ Tenant</p>
  </div>
  <div class="text-muted small">@Model.Count yêu cầu</div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show py-2 small">
    <i class="bi bi-check-circle me-1"></i>@Html.Raw(TempData["Success"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Warning"] != null)
{
  <div class="alert alert-warning alert-dismissible fade show py-2 small">
    <i class="bi bi-exclamation-triangle me-1"></i>@Html.Raw(TempData["Warning"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* Filter tabs *@
<div class="d-flex gap-2 mb-3">
  <a asp-action="BookingRequests" asp-route-filter="pending"
     class="btn btn-sm @(currentFilter == "pending" ? "btn-warning" : "btn-outline-secondary")">
    <i class="bi bi-hourglass-split me-1"></i>Đang chờ
  </a>
  <a asp-action="BookingRequests" asp-route-filter="approved"
     class="btn btn-sm @(currentFilter == "approved" ? "btn-success" : "btn-outline-secondary")">
    <i class="bi bi-check-circle me-1"></i>Đã duyệt
  </a>
  <a asp-action="BookingRequests" asp-route-filter="rejected"
     class="btn btn-sm @(currentFilter == "rejected" ? "btn-danger" : "btn-outline-secondary")">
    <i class="bi bi-x-circle me-1"></i>Từ chối
  </a>
</div>

@if (!Model.Any())
{
  <div class="text-center py-5 text-muted">
    <i class="bi bi-bookmark-x fs-1 d-block mb-2"></i>
    Không có yêu cầu đặt phòng nào.
  </div>
}
else
{
  <div class="card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Phòng</th>
          <th>Tenant</th>
          <th style="width:110px">Ngày vào ở</th>
          <th style="width:130px">Gửi lúc</th>
          <th>Lời nhắn</th>
          <th style="width:95px">Trạng thái</th>
          <th style="width:120px"></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var b in Model)
        {
          <tr>
            <td>
              <div class="small fw-semibold">Phòng @b.Room.RoomNumber</div>
              <div class="text-muted" style="font-size:11px">@b.Room.Building.Name</div>
            </td>
            <td>
              <div class="small fw-semibold">@b.Tenant.FullName</div>
              <div class="text-muted" style="font-size:11px">@b.Tenant.Email</div>
            </td>
            <td class="small">@b.DesiredMoveIn.ToString("dd/MM/yyyy")</td>
            <td class="small text-muted">@b.CreatedAt.ToString("HH:mm dd/MM/yy")</td>
            <td class="small text-muted">
              @(string.IsNullOrWhiteSpace(b.Message) ? "—" : b.Message)
            </td>
            <td>
              @if (b.Status == BookingStatus.Pending)
              {
                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Đang chờ</span>
              }
              else if (b.Status == BookingStatus.Approved)
              {
                <span class="badge bg-success-subtle text-success border border-success-subtle">Đã duyệt</span>
              }
              else
              {
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Từ chối</span>
              }
            </td>
            <td>
              @if (b.Status == BookingStatus.Pending)
              {
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-success"
                          onclick="openApprove(@b.Id, '@b.DesiredMoveIn.ToString("yyyy-MM-dd")', @b.Room.Id)"
                          title="Duyệt">
                    <i class="bi bi-check-lg me-1"></i>Duyệt
                  </button>
                  <button class="btn btn-sm btn-outline-danger"
                          onclick="openReject(@b.Id)"
                          title="Từ chối">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>
              }
              @if (b.Status == BookingStatus.Approved && b.Contract != null)
              {
                <span class="small text-success">
                  <i class="bi bi-file-earmark-check me-1"></i>HĐ #@b.Contract.Id
                </span>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@* Modal: Duyệt đặt phòng *@
<div class="modal fade" id="approveModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form asp-action="ApproveBooking" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="approveId" />
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Duyệt đặt phòng — tạo hợp đồng</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-info small py-2 mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Hợp đồng sẽ được tạo ở trạng thái <strong>Pending</strong> — bạn có thể chỉnh sửa thêm trong mục Hợp đồng.
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold small">Ngày bắt đầu <span class="text-danger">*</span></label>
              <input type="date" name="startDate" id="approveStartDate" class="form-control form-control-sm" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold small">Ngày kết thúc</label>
              <input type="date" name="endDate" class="form-control form-control-sm" />
              <div class="form-text" style="font-size:10px">Để trống = hợp đồng không xác định</div>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold small">Giá thuê (₫/tháng) <span class="text-danger">*</span></label>
              <input type="number" name="monthlyRent" id="approveRent"
                     class="form-control form-control-sm" min="0" step="100000" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold small">Tiền cọc (₫) <span class="text-danger">*</span></label>
              <input type="number" name="depositAmount" id="approveDeposit"
                     class="form-control form-control-sm" min="0" step="100000" required />
            </div>
          </div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button type="submit" class="btn btn-sm btn-success">
            <i class="bi bi-check-lg me-1"></i>Duyệt & tạo hợp đồng
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@* Modal: Từ chối *@
<div class="modal fade" id="rejectModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form asp-action="RejectBooking" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="rejectId" />
        <div class="modal-header">
          <h6 class="modal-title fw-bold">Từ chối đặt phòng</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label fw-semibold small">Lý do (tuỳ chọn)</label>
          <textarea name="rejectionReason" class="form-control form-control-sm" rows="2"
                    placeholder="VD: Phòng đã được đặt bởi người khác..."></textarea>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
          <button type="submit" class="btn btn-sm btn-danger">
            <i class="bi bi-x-circle me-1"></i>Từ chối
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
  const roomPrices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RoomPrices ?? new Dictionary<int, decimal>()));

  function openApprove(id, desiredMoveIn, roomId) {
    document.getElementById('approveId').value        = id;
    document.getElementById('approveStartDate').value = desiredMoveIn;
    
    const rentInput = document.getElementById('approveRent');
    const depositInput = document.getElementById('approveDeposit');
    
    if (roomPrices[roomId] !== undefined) {
      const fixedPrice = roomPrices[roomId];
      rentInput.value = fixedPrice;
      depositInput.value = fixedPrice;
      
      rentInput.readOnly = true;
      depositInput.readOnly = true;
      
      rentInput.classList.add('bg-light');
      depositInput.classList.add('bg-light');
    } else {
      rentInput.value = "";
      depositInput.value = "";
      
      rentInput.readOnly = false;
      depositInput.readOnly = false;
      
      rentInput.classList.remove('bg-light');
      depositInput.classList.remove('bg-light');
    }
    
    new bootstrap.Modal(document.getElementById('approveModal')).show();
  }

  function openReject(id) {
    document.getElementById('rejectId').value = id;
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
  }
</script>
}


@using StuRoom.Models
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "Dashboard";

    int    totalRooms      = (int)ViewBag.TotalRooms;
    int    occupiedRooms   = (int)ViewBag.OccupiedRooms;
    int    activeContracts = (int)ViewBag.ActiveContracts;
    int    unpaidInvoices  = (int)ViewBag.UnpaidInvoices;
    double occupancyRate   = (double)ViewBag.OccupancyRate;
    var    revenueLabels   = (List<string>)ViewBag.RevenueLabels;
    var    revenueData     = (List<decimal>)ViewBag.RevenueData;
    var    overdueInvoices = (List<Invoice>)ViewBag.OverdueInvoices;
    var    recentContracts = (List<Contract>)ViewBag.RecentContracts;

    string revenueLabelsJson = System.Text.Json.JsonSerializer.Serialize(revenueLabels);
    string revenueDataJson   = System.Text.Json.JsonSerializer.Serialize(revenueData);
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0">Dashboard</h4>
    <p class="text-muted small mb-0">Tổng quan hoạt động</p>
  </div>
  <span class="text-muted small">@DateTime.Now.ToString("dd/MM/yyyy")</span>
</div>

@* ── Stats Cards ── *@
<div class="row g-3 mb-4">
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#e0e7ff">
          <i class="bi bi-door-open fs-4" style="color:#4f46e5"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold mb-0">@occupiedRooms / @totalRooms</div>
          <div class="text-muted small">Phòng đang thuê</div>
          <div class="small text-primary">@occupancyRate% lấp đầy</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#dcfce7">
          <i class="bi bi-file-earmark-text fs-4" style="color:#16a34a"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold mb-0">@activeContracts</div>
          <div class="text-muted small">Hợp đồng đang thuê</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#fef9c3">
          <i class="bi bi-receipt fs-4" style="color:#ca8a04"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold mb-0 @(unpaidInvoices > 0 ? "text-warning" : "")">
            @unpaidInvoices
          </div>
          <div class="text-muted small">Hoá đơn chưa thanh toán</div>
          @if (unpaidInvoices > 0)
          {
            <a asp-action="Invoices" asp-route-filter="unpaid"
               class="small text-warning">Xem ngay →</a>
          }
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#fee2e2">
          <i class="bi bi-exclamation-circle fs-4" style="color:#dc2626"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold mb-0 @(overdueInvoices.Count > 0 ? "text-danger" : "")">
            @overdueInvoices.Count
          </div>
          <div class="text-muted small">Hoá đơn quá hạn</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">

  @* ── Revenue Chart ── *@
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent py-2 d-flex align-items-center justify-content-between">
        <span class="fw-semibold small">
          <i class="bi bi-bar-chart me-1"></i>Doanh thu 12 tháng gần nhất
        </span>
        <span class="text-muted small">
          Tổng: @revenueData.Sum().ToString("N0") ₫
        </span>
      </div>
      <div class="card-body">
        <canvas id="revenueChart" height="100"></canvas>
      </div>
    </div>
  </div>

  @* ── Occupancy Doughnut ── *@
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent py-2 fw-semibold small">
        <i class="bi bi-pie-chart me-1"></i>Tỷ lệ lấp đầy
      </div>
      <div class="card-body d-flex flex-column align-items-center justify-content-center">
        <canvas id="occupancyChart" width="200" height="200"></canvas>
        <div class="mt-3 d-flex gap-4 small">
          <span><i class="bi bi-circle-fill me-1" style="color:#4f46e5"></i>Đang thuê (@occupiedRooms)</span>
          <span><i class="bi bi-circle-fill me-1 text-secondary"></i>Trống (@(totalRooms - occupiedRooms))</span>
        </div>
      </div>
    </div>
  </div>

  @* ── Overdue Invoices ── *@
  @if (overdueInvoices.Any())
  {
    <div class="col-12">
      <div class="card border-0 shadow-sm border-danger" style="border-left:4px solid #dc2626!important">
        <div class="card-header bg-transparent py-2 d-flex align-items-center gap-2">
          <i class="bi bi-exclamation-triangle text-danger"></i>
          <span class="fw-semibold small text-danger">Hoá đơn quá hạn</span>
        </div>
        <div class="card-body p-0">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Phòng / Tenant</th>
                <th style="width:80px">Kỳ</th>
                <th style="width:120px">Tổng tiền</th>
                <th style="width:100px">Hạn</th>
                <th style="width:60px"></th>
              </tr>
            </thead>
            <tbody>
              @foreach (var inv in overdueInvoices)
              {
                var daysOverdue = (int)(DateTime.Now - inv.DueDate).TotalDays;
                <tr>
                  <td>
                    <div class="small fw-semibold">Phòng @inv.Contract.Room.RoomNumber</div>
                    <div class="text-muted" style="font-size:11px">
                      @inv.Contract.Tenant.FullName — @inv.Contract.Room.Building.Name
                    </div>
                  </td>
                  <td class="small">@inv.BillingMonth/@inv.BillingYear</td>
                  <td class="small fw-semibold">@inv.TotalAmount.ToString("N0") ₫</td>
                  <td class="small text-danger fw-semibold">
                    @inv.DueDate.ToString("dd/MM/yy")
                    <div style="font-size:10px">quá @daysOverdue ngày</div>
                  </td>
                  <td>
                    <a asp-action="InvoiceDetail" asp-route-id="@inv.Id"
                       class="btn btn-sm btn-outline-danger" title="Chi tiết">
                      <i class="bi bi-eye"></i>
                    </a>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }

  @* ── Recent Active Contracts ── *@
  @if (recentContracts.Any())
  {
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent py-2 fw-semibold small">
          <i class="bi bi-file-earmark-check me-1"></i>Hợp đồng đang thuê gần đây
        </div>
        <div class="card-body p-0">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Phòng</th>
                <th>Tenant</th>
                <th style="width:100px">Bắt đầu</th>
                <th style="width:100px">Kết thúc</th>
                <th style="width:110px">Giá thuê</th>
                <th style="width:60px"></th>
              </tr>
            </thead>
            <tbody>
              @foreach (var c in recentContracts)
              {
                <tr>
                  <td>
                    <div class="small fw-semibold">Phòng @c.Room.RoomNumber</div>
                    <div class="text-muted" style="font-size:11px">@c.Room.Building.Name</div>
                  </td>
                  <td>
                    <div class="small fw-semibold">@c.Tenant.FullName</div>
                    <div class="text-muted" style="font-size:11px">@c.Tenant.Email</div>
                  </td>
                  <td class="small">@c.StartDate.ToString("dd/MM/yyyy")</td>
                  <td class="small text-muted">
                    @(c.EndDate.HasValue ? c.EndDate.Value.ToString("dd/MM/yyyy") : "—")
                  </td>
                  <td class="small fw-semibold">@c.MonthlyRent.ToString("N0") ₫</td>
                  <td>
                    <a asp-action="ContractDetail" asp-route-id="@c.Id"
                       class="btn btn-sm btn-outline-primary" title="Chi tiết">
                      <i class="bi bi-eye"></i>
                    </a>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Revenue bar chart
new Chart(document.getElementById('revenueChart'), {
  type: 'bar',
  data: {
    labels: @Html.Raw(revenueLabelsJson),
    datasets: [{
      label: 'Doanh thu (₫)',
      data: @Html.Raw(revenueDataJson),
      backgroundColor: 'rgba(79,70,229,0.7)',
      borderColor: 'rgba(79,70,229,1)',
      borderWidth: 1,
      borderRadius: 4,
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      y: {
        beginAtZero: true,
        ticks: {
          callback: v => new Intl.NumberFormat('vi-VN',
            { notation: 'compact', maximumFractionDigits: 1 }).format(v) + ' ₫'
        }
      }
    }
  }
});

// Occupancy doughnut
new Chart(document.getElementById('occupancyChart'), {
  type: 'doughnut',
  data: {
    labels: ['Đang thuê', 'Trống'],
    datasets: [{
      data: [@occupiedRooms, @(totalRooms - occupiedRooms)],
      backgroundColor: ['#4f46e5', '#e5e7eb'],
      borderWidth: 0,
    }]
  },
  options: {
    cutout: '70%',
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          label: ctx => ` ${ctx.label}: ${ctx.raw} phòng`
        }
      }
    }
  }
});
</script>
}

@model List<StuRoom.Models.Room>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Phòng";
    var buildings     = (List<StuRoom.Models.Building>)ViewBag.Buildings;
    var buildingId    = (int?)ViewBag.BuildingId;
    var selectedBuilding = buildings.FirstOrDefault(b => b.Id == buildingId);

    var statusLabels = new Dictionary<StuRoom.Models.RoomStatus, (string label, string css)>
    {
        [StuRoom.Models.RoomStatus.Available]   = ("Trống",       "bg-success-subtle text-success border border-success-subtle"),
        [StuRoom.Models.RoomStatus.Occupied]    = ("Đã thuê",     "bg-primary-subtle text-primary border border-primary-subtle"),
        [StuRoom.Models.RoomStatus.Maintenance] = ("Bảo trì",     "bg-warning-subtle text-warning border border-warning-subtle"),
        [StuRoom.Models.RoomStatus.Inactive]    = ("Không hoạt động", "bg-secondary-subtle text-secondary border border-secondary-subtle"),
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0">
      Phòng
      @if (selectedBuilding != null)
      {
        <span class="text-muted fw-normal fs-6">— @selectedBuilding.Name</span>
      }
    </h4>
    <p class="text-muted small mb-0">Quản lý phòng trong tòa nhà</p>
  </div>
  <div class="d-flex gap-2">
    @if (buildings.Any())
    {
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createRoomModal">
        <i class="bi bi-plus-lg me-1"></i>Thêm phòng
      </button>
    }
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show py-2 small">
    <i class="bi bi-check-circle me-1"></i>@Html.Raw(TempData["Success"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show py-2 small">
    <i class="bi bi-exclamation-circle me-1"></i>@Html.Raw(TempData["Error"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* ── Bộ lọc theo tòa nhà ── *@
<div class="d-flex flex-wrap gap-2 mb-3">
  <a asp-action="Rooms"
     class="btn btn-sm @(buildingId == null ? "btn-primary" : "btn-outline-secondary")">
    Tất cả
  </a>
  @foreach (var b in buildings)
  {
    <a asp-action="Rooms" asp-route-buildingId="@b.Id"
       class="btn btn-sm @(buildingId == b.Id ? "btn-primary" : "btn-outline-secondary")">
      @b.Name
    </a>
  }
</div>

@if (!buildings.Any())
{
  <div class="text-center py-5 text-muted">
    <i class="bi bi-building fs-1 d-block mb-2"></i>
    Bạn chưa có tòa nhà nào. <a asp-action="Buildings">Thêm tòa nhà trước</a>.
  </div>
}
else if (!Model.Any())
{
  <div class="text-center py-5 text-muted">
    <i class="bi bi-door-open fs-1 d-block mb-2"></i>
    Chưa có phòng nào@(buildingId.HasValue ? " trong tòa nhà này" : "").
  </div>
}
else
{
  <div class="card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Số phòng</th>
          <th>Tòa nhà</th>
          <th style="width:60px">Tầng</th>
          <th style="width:80px">Diện tích</th>
          <th style="width:80px">Sức chứa</th>
          <th>Mô tả</th>
          <th style="width:110px">Trạng thái</th>
          <th style="width:90px"></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var r in Model)
        {
          var (lbl, css) = statusLabels[r.Status];
          <tr>
            <td class="fw-semibold">@r.RoomNumber</td>
            <td class="small text-muted">@r.Building.Name</td>
            <td class="small text-muted text-center">@(r.FloorNumber?.ToString() ?? "—")</td>
            <td class="small">@r.Area m²</td>
            <td class="small text-center">@(r.Capacity?.ToString() ?? "∞")</td>
            <td>
              <span class="small text-muted"
                    style="display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">
                @(string.IsNullOrWhiteSpace(r.Description) ? "—" : r.Description)
              </span>
            </td>
            <td><span class="badge @css">@lbl</span></td>
            <td>
              <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-secondary"
                        title="Sửa"
                        onclick="openEditRoom(@r.Id, @r.BuildingId, '@Html.Encode(r.RoomNumber)', @(r.FloorNumber.HasValue ? r.FloorNumber.Value.ToString() : "null"), @r.Area.ToString("G", System.Globalization.CultureInfo.InvariantCulture), @(r.Capacity.HasValue ? r.Capacity.Value.ToString() : "null"), '@Html.Encode(r.Description ?? "")', @(buildingId.HasValue ? buildingId.Value.ToString() : "null"))">
                  <i class="bi bi-pencil"></i>
                </button>
                <form asp-action="DeleteRoom" method="post" class="d-inline">
                  <input type="hidden" name="id" value="@r.Id" />
                  <input type="hidden" name="returnBuildingId" value="@buildingId" />
                  <button type="submit" class="btn btn-sm btn-outline-danger"
                          title="Xoá"
                          onclick="return confirm('Xoá phòng @Html.Encode(r.RoomNumber)?')">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@* ── Modal: Thêm phòng ── *@
<div class="modal fade" id="createRoomModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form asp-action="CreateRoom" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Thêm phòng</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Tòa nhà <span class="text-danger">*</span></label>
            <select name="buildingId" id="createRoomBuilding" class="form-select" required>
              <option value="">— Chọn tòa nhà —</option>
              @foreach (var b in buildings)
              {
                if (buildingId == b.Id)
                {
                  <option value="@b.Id" selected>@b.Name</option>
                }
                else
                {
                  <option value="@b.Id">@b.Name</option>
                }
              }
            </select>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold">Số phòng <span class="text-danger">*</span></label>
              <input type="text" name="roomNumber" class="form-control" placeholder="VD: 101" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Tầng</label>
              <input type="number" name="floorNumber" class="form-control" placeholder="VD: 1" min="0" />
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold">Diện tích (m²) <span class="text-danger">*</span></label>
              <input type="number" name="area" class="form-control" placeholder="VD: 20" min="1" step="0.1" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Sức chứa (người)</label>
              <input type="number" name="capacity" class="form-control" placeholder="Để trống = không giới hạn" min="1" />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Mô tả</label>
            <textarea name="description" class="form-control" rows="2"
                      placeholder="Ghi chú về phòng (tuỳ chọn)"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Thêm
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@* ── Modal: Sửa phòng ── *@
<div class="modal fade" id="editRoomModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form asp-action="EditRoom" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="editRoomId" />
        <input type="hidden" name="returnBuildingId" id="editRoomReturnBuilding" />
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Sửa phòng</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Tòa nhà</label>
            <select name="buildingIdDisplay" id="editRoomBuilding" class="form-select" disabled>
              @foreach (var b in buildings)
              {
                <option value="@b.Id">@b.Name</option>
              }
            </select>
            <small class="text-muted">Không thể thay đổi tòa nhà của phòng.</small>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold">Số phòng <span class="text-danger">*</span></label>
              <input type="text" name="roomNumber" id="editRoomNumber" class="form-control" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Tầng</label>
              <input type="number" name="floorNumber" id="editRoomFloor" class="form-control" min="0" />
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold">Diện tích (m²) <span class="text-danger">*</span></label>
              <input type="number" name="area" id="editRoomArea" class="form-control" min="1" step="0.1" required />
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Sức chứa (người)</label>
              <input type="number" name="capacity" id="editRoomCapacity" class="form-control" min="1" />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Mô tả</label>
            <textarea name="description" id="editRoomDesc" class="form-control" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Lưu
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    function openEditRoom(id, buildingId, roomNumber, floorNumber, area, capacity, description, returnBuildingId) {
      document.getElementById('editRoomId').value             = id;
      document.getElementById('editRoomReturnBuilding').value = returnBuildingId ?? '';
      document.getElementById('editRoomBuilding').value       = buildingId;
      document.getElementById('editRoomNumber').value         = roomNumber;
      document.getElementById('editRoomFloor').value          = floorNumber ?? '';
      document.getElementById('editRoomArea').value           = area;
      document.getElementById('editRoomCapacity').value       = capacity ?? '';
      document.getElementById('editRoomDesc').value           = description;
      new bootstrap.Modal(document.getElementById('editRoomModal')).show();
    }
  </script>
}

@model List<StuRoom.Models.Invoice>
@using StuRoom.Models
@{
    ViewData["Title"] = "Hoá đơn";
    var currentFilter = ViewData["Filter"]?.ToString() ?? "unpaid";
    var buildings     = (List<Building>)ViewBag.Buildings;
    var buildingId    = (int?)ViewBag.BuildingId;

    var statusMap = new Dictionary<InvoiceStatus, (string label, string css)>
    {
        [InvoiceStatus.Draft]     = ("Nháp",       "bg-secondary-subtle text-secondary border border-secondary-subtle"),
        [InvoiceStatus.Sent]      = ("Đã gửi",     "bg-info-subtle text-info border border-info-subtle"),
        [InvoiceStatus.Paid]      = ("Đã thanh toán","bg-success-subtle text-success border border-success-subtle"),
        [InvoiceStatus.Overdue]   = ("Quá hạn",    "bg-danger-subtle text-danger border border-danger-subtle"),
        [InvoiceStatus.Cancelled] = ("Đã huỷ",     "bg-light text-muted border"),
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0">Hoá đơn</h4>
    <p class="text-muted small mb-0">Quản lý hoá đơn tiền phòng</p>
  </div>
  <div class="text-muted small">@Model.Count hoá đơn</div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show py-2 small">
    <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show py-2 small">
    <i class="bi bi-exclamation-circle me-1"></i>@TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* Filters *@
<div class="d-flex flex-wrap gap-2 mb-3">
  <div class="d-flex gap-1">
    <a asp-action="Invoices" asp-route-filter="unpaid" asp-route-buildingId="@buildingId"
       class="btn btn-sm @(currentFilter == "unpaid" ? "btn-warning" : "btn-outline-secondary")">
      Chưa thanh toán
    </a>
    <a asp-action="Invoices" asp-route-filter="paid" asp-route-buildingId="@buildingId"
       class="btn btn-sm @(currentFilter == "paid" ? "btn-success" : "btn-outline-secondary")">
      Đã thanh toán
    </a>
    <a asp-action="Invoices" asp-route-filter="overdue" asp-route-buildingId="@buildingId"
       class="btn btn-sm @(currentFilter == "overdue" ? "btn-danger" : "btn-outline-secondary")">
      Quá hạn
    </a>
    <a asp-action="Invoices" asp-route-filter="all" asp-route-buildingId="@buildingId"
       class="btn btn-sm @(currentFilter == "all" ? "btn-primary" : "btn-outline-secondary")">
      Tất cả
    </a>
  </div>

  @if (buildings.Any())
  {
    <div class="d-flex gap-1 ms-auto">
      <a asp-action="Invoices" asp-route-filter="@currentFilter"
         class="btn btn-sm @(buildingId == null ? "btn-primary" : "btn-outline-secondary")">
        Tất cả tòa nhà
      </a>
      @foreach (var b in buildings)
      {
        <a asp-action="Invoices" asp-route-filter="@currentFilter" asp-route-buildingId="@b.Id"
           class="btn btn-sm @(buildingId == b.Id ? "btn-primary" : "btn-outline-secondary")">
          @b.Name
        </a>
      }
    </div>
  }
</div>

@if (!Model.Any())
{
  <div class="text-center py-5 text-muted">
    <i class="bi bi-receipt fs-1 d-block mb-2"></i>
    Không có hoá đơn nào.
  </div>
}
else
{
  <div class="card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th style="width:50px">#</th>
          <th>Phòng / Tenant</th>
          <th style="width:90px">Kỳ</th>
          <th style="width:110px">Tổng tiền</th>
          <th style="width:100px">Hạn</th>
          <th style="width:120px">Trạng thái</th>
          <th style="width:60px"></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var inv in Model)
        {
          var (lbl, css) = statusMap[inv.Status];
          var isOverdue  = inv.Status != InvoiceStatus.Paid
                        && inv.Status != InvoiceStatus.Cancelled
                        && inv.DueDate < DateTime.Now;
          <tr>
            <td class="text-muted small">@inv.Id</td>
            <td>
              <div class="small fw-semibold">Phòng @inv.Contract.Room.RoomNumber</div>
              <div class="text-muted" style="font-size:11px">
                @inv.Contract.Tenant.FullName — @inv.Contract.Room.Building.Name
              </div>
            </td>
            <td class="small fw-semibold">@inv.BillingMonth/@inv.BillingYear</td>
            <td class="small fw-semibold">@inv.TotalAmount.ToString("N0") ₫</td>
            <td class="small @(isOverdue ? "text-danger fw-semibold" : "text-muted")">
              @inv.DueDate.ToString("dd/MM/yy")
              @if (isOverdue) { <i class="bi bi-exclamation-circle ms-1"></i> }
            </td>
            <td><span class="badge @css" style="font-size:11px">@lbl</span></td>
            <td>
              <a asp-action="InvoiceDetail" asp-route-id="@inv.Id"
                 class="btn btn-sm btn-outline-primary" title="Chi tiết">
                <i class="bi bi-eye"></i>
              </a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

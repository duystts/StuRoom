@model List<StuRoom.Models.ViewingRequest>
@using StuRoom.Models
@{
    ViewData["Title"] = "Lịch hẹn xem phòng";
    var currentFilter = ViewData["Filter"]?.ToString() ?? "pending";

    var statusMap = new Dictionary<ViewingStatus, (string label, string css, string icon)>
    {
        [ViewingStatus.Pending]     = ("Đang chờ",   "bg-warning-subtle text-warning border border-warning-subtle",    "bi-hourglass-split"),
        [ViewingStatus.Confirmed]   = ("Đã xác nhận","bg-success-subtle text-success border border-success-subtle",    "bi-check-circle"),
        [ViewingStatus.Rescheduled] = ("Đổi giờ",    "bg-info-subtle text-info border border-info-subtle",            "bi-arrow-repeat"),
        [ViewingStatus.Cancelled]   = ("Đã huỷ",     "bg-danger-subtle text-danger border border-danger-subtle",      "bi-x-circle"),
        [ViewingStatus.Completed]   = ("Hoàn thành", "bg-secondary-subtle text-secondary border border-secondary-subtle","bi-check-all"),
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0">Lịch hẹn xem phòng</h4>
    <p class="text-muted small mb-0">Quản lý lịch hẹn từ Tenant</p>
  </div>
  <div class="text-muted small">@Model.Count lịch hẹn</div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show py-2 small">
    <i class="bi bi-check-circle me-1"></i>@Html.Raw(TempData["Success"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Warning"] != null)
{
  <div class="alert alert-warning alert-dismissible fade show py-2 small">
    <i class="bi bi-exclamation-triangle me-1"></i>@Html.Raw(TempData["Warning"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* Filter tabs *@
<div class="d-flex gap-2 mb-3 flex-wrap">
  <a asp-action="ViewingRequests" asp-route-filter="pending"
     class="btn btn-sm @(currentFilter == "pending" ? "btn-warning" : "btn-outline-secondary")">
    <i class="bi bi-hourglass-split me-1"></i>Đang chờ
  </a>
  <a asp-action="ViewingRequests" asp-route-filter="confirmed"
     class="btn btn-sm @(currentFilter == "confirmed" ? "btn-success" : "btn-outline-secondary")">
    <i class="bi bi-check-circle me-1"></i>Đã xác nhận / Đổi giờ
  </a>
  <a asp-action="ViewingRequests" asp-route-filter="completed"
     class="btn btn-sm @(currentFilter == "completed" ? "btn-secondary" : "btn-outline-secondary")">
    <i class="bi bi-archive me-1"></i>Hoàn thành / Đã huỷ
  </a>
</div>

@if (!Model.Any())
{
  <div class="text-center py-5 text-muted">
    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
    Không có lịch hẹn nào.
  </div>
}
else
{
  <div class="card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Phòng</th>
          <th>Tenant</th>
          <th style="width:160px">Thời gian đề xuất</th>
          <th style="width:160px">Giờ xác nhận</th>
          <th style="width:100px">Trạng thái</th>
          <th style="width:180px">Ghi chú</th>
          <th style="width:160px"></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var v in Model)
        {
          var (lbl, css, icon) = statusMap[v.Status];
          <tr>
            <td>
              <div class="small fw-semibold">Phòng @v.Room.RoomNumber</div>
              <div class="text-muted" style="font-size:11px">@v.Room.Building.Name</div>
            </td>
            <td>
              <div class="small fw-semibold">@v.Tenant.FullName</div>
              <div class="text-muted" style="font-size:11px">@v.Tenant.Email</div>
            </td>
            <td class="small">@v.ProposedTime.ToString("HH:mm dd/MM/yy")</td>
            <td class="small">
              @(v.ConfirmedTime.HasValue ? v.ConfirmedTime.Value.ToString("HH:mm dd/MM/yy") : "—")
            </td>
            <td>
              <span class="badge @css" style="font-size:11px">
                <i class="bi @icon me-1"></i>@lbl
              </span>
            </td>
            <td class="small text-muted">
              @if (!string.IsNullOrWhiteSpace(v.TenantNote))
              {
                <div><i class="bi bi-person-lines-fill me-1"></i>@v.TenantNote</div>
              }
              @if (!string.IsNullOrWhiteSpace(v.LandlordNote))
              {
                <div class="mt-1"><i class="bi bi-house me-1"></i>@v.LandlordNote</div>
              }
            </td>
            <td>
              <div class="d-flex gap-1 flex-wrap">
                @if (v.Status == ViewingStatus.Pending || v.Status == ViewingStatus.Rescheduled)
                {
                  @* Confirm *@
                  <button class="btn btn-sm btn-outline-success"
                          title="Xác nhận"
                          onclick="openConfirm(@v.Id, '@v.ProposedTime.ToString("yyyy-MM-ddTHH:mm")')">
                    <i class="bi bi-check-lg"></i>
                  </button>
                  @* Reschedule *@
                  <button class="btn btn-sm btn-outline-info"
                          title="Đổi giờ"
                          onclick="openReschedule(@v.Id)">
                    <i class="bi bi-arrow-repeat"></i>
                  </button>
                }
                @if (v.Status == ViewingStatus.Confirmed)
                {
                  @* Complete *@
                  <form asp-action="CompleteViewing" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@v.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                            title="Đánh dấu hoàn thành">
                      <i class="bi bi-check-all"></i>
                    </button>
                  </form>
                }
                @if (v.Status != ViewingStatus.Cancelled && v.Status != ViewingStatus.Completed)
                {
                  @* Cancel *@
                  <button class="btn btn-sm btn-outline-danger"
                          title="Huỷ"
                          onclick="openCancel(@v.Id)">
                    <i class="bi bi-x-lg"></i>
                  </button>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@* Modal: Xác nhận lịch hẹn *@
<div class="modal fade" id="confirmModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form asp-action="ConfirmViewing" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="confirmId" />
        <div class="modal-header">
          <h6 class="modal-title fw-bold">Xác nhận lịch hẹn</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label fw-semibold small">Giờ xác nhận</label>
          <input type="datetime-local" name="confirmedTime" id="confirmedTime"
                 class="form-control form-control-sm" />
          <div class="form-text">Để trống = dùng giờ Tenant đề xuất</div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button type="submit" class="btn btn-sm btn-success">
            <i class="bi bi-check-lg me-1"></i>Xác nhận
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@* Modal: Đổi giờ *@
<div class="modal fade" id="rescheduleModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form asp-action="RescheduleViewing" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="rescheduleId" />
        <div class="modal-header">
          <h6 class="modal-title fw-bold">Đề xuất đổi giờ</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold small">Giờ mới <span class="text-danger">*</span></label>
            <input type="datetime-local" name="newTime" id="newTime"
                   class="form-control" required
                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Ghi chú cho Tenant</label>
            <textarea name="landlordNote" class="form-control form-control-sm" rows="2"
                      placeholder="VD: Xin lỗi vì bất tiện, tôi bận vào giờ đó..."></textarea>
          </div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button type="submit" class="btn btn-sm btn-info text-white">
            <i class="bi bi-send me-1"></i>Gửi đề xuất
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@* Modal: Huỷ *@
<div class="modal fade" id="cancelModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form asp-action="CancelViewing" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="cancelId" />
        <div class="modal-header">
          <h6 class="modal-title fw-bold">Huỷ lịch hẹn</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label fw-semibold small">Lý do (tuỳ chọn)</label>
          <textarea name="landlordNote" class="form-control form-control-sm" rows="2"
                    placeholder="VD: Phòng vừa có người thuê..."></textarea>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
          <button type="submit" class="btn btn-sm btn-danger">
            <i class="bi bi-x-circle me-1"></i>Huỷ lịch
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
  function openConfirm(id, proposedTime) {
    document.getElementById('confirmId').value    = id;
    document.getElementById('confirmedTime').value = proposedTime;
    new bootstrap.Modal(document.getElementById('confirmModal')).show();
  }
  function openReschedule(id) {
    document.getElementById('rescheduleId').value = id;
    new bootstrap.Modal(document.getElementById('rescheduleModal')).show();
  }
  function openCancel(id) {
    document.getElementById('cancelId').value = id;
    new bootstrap.Modal(document.getElementById('cancelModal')).show();
  }
</script>
}

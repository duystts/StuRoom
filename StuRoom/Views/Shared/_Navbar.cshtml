@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using StuRoom.Data
@using StuRoom.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext NavbarDb
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>()?.RequestCulture;
    var currentCulture = requestCulture?.Culture.Name ?? "vi";
    var isSignedIn  = SignInManager.IsSignedIn(User);
    var isLandlord  = User.IsInRole("Landlord");
    var isAdmin     = User.IsInRole("Admin");
    var isTenant    = User.IsInRole("Tenant");
    ApplicationUser? currentUser = isSignedIn
        ? await UserManager.GetUserAsync(User)
        : null;

    int unreadCount = 0;
    if (isSignedIn && currentUser != null)
    {
        unreadCount = await NavbarDb.Notifications
            .CountAsync(n => n.UserId == currentUser.Id && !n.IsRead);
    }
}

<nav class="navbar navbar-expand-lg sturoom-navbar border-bottom">
  <div class="container-fluid px-4">

    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
      StuRoom
    </a>

    @* Mobile toggler *@
    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse" data-bs-target="#navbarMain"
            aria-controls="navbarMain" aria-expanded="false" aria-label="Mở menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">

      @* ── Left links (Guest / Tenant) ── *@
      <ul class="navbar-nav me-auto">
        @if (!isLandlord && !isAdmin)
        {
          <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="Index">
              @Localizer["Trang chủ"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="Rooms" asp-action="Index">
              @Localizer["Cho thuê"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="Rooms" asp-action="Index" asp-route-Q="ghép">
              @Localizer["Tìm ở ghép"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#blog">
              @Localizer["Bài viết"]
            </a>
          </li>
        }
        @if (isTenant)
        {
          <li class="nav-item border-start ps-2 ms-2 d-none d-lg-block"></li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="TenantRentals" asp-action="Index">
              <i class="bi bi-house-door me-1"></i>@Localizer["Phòng đang thuê"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="ViewingRequests" asp-action="Index">
              <i class="bi bi-calendar-check me-1"></i>@Localizer["Lịch hẹn"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="BookingRequests" asp-action="Index">
              <i class="bi bi-bookmark-check me-1"></i>@Localizer["Đặt phòng"]
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="Rooms" asp-action="Favorites">
              <i class="bi bi-heart-fill text-danger me-1"></i>@Localizer["Yêu thích"]
            </a>
          </li>
        }
      </ul>

      <ul class="navbar-nav ms-auto align-items-center">
        @* Theme Toggle *@
        <li class="nav-item me-2">
          <button id="themeToggle" class="btn btn-link nav-link px-2 text-secondary theme-toggle-btn" type="button" title="@Localizer["Chuyển chế độ sáng/tối"]">
            <i class="bi bi-moon fs-5"></i>
          </button>
        </li>
        @if (isSignedIn && currentUser != null)
        {
          @if (isLandlord)
          {
            <li class="nav-item me-2 d-none d-md-block">
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                 asp-controller="Landlord" asp-action="Rooms">
                <i class="bi bi-plus-circle me-1"></i>@Localizer["Đăng tin"]
              </a>
            </li>
          }
          @* Bell notification dropdown *@
          <li class="nav-item dropdown me-1">
            <a class="nav-link position-relative px-2"
               href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false"
               id="notifBell">
              <i class="bi bi-bell fs-5"></i>
              @if (unreadCount > 0)
              {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="font-size:9px;padding:2px 5px">
                  @(unreadCount > 99 ? "99+" : unreadCount.ToString())
                </span>
              }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 p-0"
                style="min-width:320px;max-height:420px;overflow-y:auto">
              <li class="px-3 py-2 border-bottom d-flex align-items-center justify-content-between">
                <span class="fw-semibold small">@Localizer["Thông báo"]</span>
                @if (unreadCount > 0)
                {
                  <form asp-controller="Notifications" asp-action="MarkAllRead" method="post" class="mb-0">
                    <button type="submit" class="btn btn-link btn-sm p-0 text-primary small">
                      @Localizer["Đọc tất cả"]
                    </button>
                  </form>
                }
              </li>
              @await Html.PartialAsync("~/Views/Notifications/_NotificationDropdown.cshtml",
                  await NavbarDb.Notifications
                      .Where(n => n.UserId == currentUser.Id && !n.IsRead)
                      .OrderByDescending(n => n.CreatedAt)
                      .Take(10)
                      .ToListAsync())
            </ul>
          </li>
        }
        @if (isSignedIn && currentUser != null)
        {
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-1 pe-0"
               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <img src="@(string.IsNullOrEmpty(currentUser.AvatarUrl) ? "/img/avatar-default.svg" : currentUser.AvatarUrl)"
                   onerror="this.src='/img/avatar-default.svg'"
                   alt="Avatar"
                   class="rounded-circle border"
                   width="32" height="32"
                   style="object-fit:cover" />
              <span class="d-none d-lg-inline small fw-semibold">
                @(currentUser.FullName ?? User.Identity?.Name)
              </span>
              @if (isLandlord)
              {
                <span class="badge bg-primary" style="font-size:10px">@Localizer["Chủ trọ"]</span>
              }
              else if (isAdmin)
              {
                <span class="badge bg-purple text-white" style="font-size:10px;background:#7c3aed!important">Admin</span>
              }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="min-width:200px">
              <li>
                <span class="dropdown-item-text small text-muted">
                  @(currentUser.Email)
                </span>
              </li>
              <li><hr class="dropdown-divider my-1" /></li>
              <li>
                <a class="dropdown-item small" asp-area="Identity" asp-page="/Account/Manage/Index">
                  <i class="bi bi-person me-2 text-muted"></i>@Localizer["Thông tin cá nhân"]
                </a>
              </li>
              <li>
                <a class="dropdown-item small" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                  <i class="bi bi-key me-2 text-muted"></i>@Localizer["Đổi mật khẩu"]
                </a>
              </li>
              <li><hr class="dropdown-divider my-1" /></li>
              <li>
                <form asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="/" method="post">
                  <button type="submit" class="dropdown-item small text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>@Localizer["Đăng xuất"]
                  </button>
                </form>
              </li>
            </ul>
          </li>
        }
        else
        {
          <li class="nav-item me-2">
            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
               asp-area="Identity" asp-page="/Account/Register" asp-route-role="Landlord">
              <i class="bi bi-plus-circle me-1"></i>@Localizer["Đăng tin"]
            </a>
          </li>
          <li class="nav-item">
            <a class="btn btn-light btn-sm rounded-pill border px-3 text-secondary" asp-area="Identity" asp-page="/Account/Login">@Localizer["Đăng nhập"]</a>
          </li>
          <li class="nav-item ms-1">
            <a class="btn btn-primary btn-sm rounded-pill px-3"
               asp-area="Identity" asp-page="/Account/Register">@Localizer["Đăng ký"]</a>
          </li>
        }
      </ul>

    </div>
  </div>
</nav>

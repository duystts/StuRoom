@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    var active = ViewData["ActiveMenu"]?.ToString() ?? "";
}

<aside class="sturoom-sidebar" id="landlordSidebar">
  <nav>
    <div class="sidebar-section-label">@Localizer["Quản lý"]</div>

    <a class="sidebar-link @(active == "Dashboard" ? "active" : "")"
       asp-controller="Landlord" asp-action="Dashboard">
      <i class="bi bi-grid-1x2"></i>
      <span>Dashboard</span>
    </a>

    <a class="sidebar-link @(active == "Buildings" ? "active" : "")"
       asp-controller="Landlord" asp-action="Buildings">
      <i class="bi bi-building"></i>
      <span>@Localizer["Tòa nhà"]</span>
    </a>

    <a class="sidebar-link @(active == "Rooms" ? "active" : "")"
       asp-controller="Landlord" asp-action="Rooms">
      <i class="bi bi-door-open"></i>
      <span>@Localizer["Phòng"]</span>
    </a>

    <a class="sidebar-link @(active == "FeeConfigs" ? "active" : "")"
       asp-controller="Landlord" asp-action="FeeConfigs">
      <i class="bi bi-sliders"></i>
      <span>@Localizer["Cấu hình phí"]</span>
    </a>

    <div class="sidebar-section-label mt-3">@Localizer["Nghiệp vụ"]</div>

    <a class="sidebar-link @(active == "ViewingRequests" ? "active" : "")"
       asp-controller="Landlord" asp-action="ViewingRequests">
      <i class="bi bi-calendar-check"></i>
      <span>@Localizer["Lịch hẹn xem"]</span>
    </a>

    <a class="sidebar-link @(active == "BookingRequests" ? "active" : "")"
       asp-controller="Landlord" asp-action="BookingRequests">
      <i class="bi bi-bookmark-check"></i>
      <span>@Localizer["Đặt phòng"]</span>
    </a>

    <a class="sidebar-link @(active == "Contracts" ? "active" : "")"
       asp-controller="Landlord" asp-action="Contracts">
      <i class="bi bi-file-earmark-text"></i>
      <span>@Localizer["Hợp đồng"]</span>
    </a>

    <a class="sidebar-link @(active == "Invoices" ? "active" : "")"
       asp-controller="Landlord" asp-action="Invoices">
      <i class="bi bi-receipt"></i>
      <span>@Localizer["Hoá đơn"]</span>
    </a>
  </nav>
</aside>

@* Mobile sidebar toggle button *@
<button class="sturoom-sidebar-toggle d-lg-none"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#mobileSidebar"
        aria-label="Mở menu">
  <i class="bi bi-layout-sidebar"></i>
</button>

@* Mobile offcanvas *@
<div class="offcanvas offcanvas-start sturoom-offcanvas" tabindex="-1" id="mobileSidebar">
  <div class="offcanvas-header border-bottom">
    <span class="fw-bold" style="color:#6c8fff;font-size:18px">Stu<span style="color:#fff">Room</span></span>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body p-0">
    <nav>
      <div class="sidebar-section-label">@Localizer["Quản lý"]</div>
      <a class="sidebar-link @(active == "Dashboard" ? "active" : "")" href="#">
        <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
      </a>
      <a class="sidebar-link @(active == "Buildings" ? "active" : "")"
         asp-controller="Landlord" asp-action="Buildings">
        <i class="bi bi-building"></i><span>@Localizer["Tòa nhà"]</span>
      </a>
      <a class="sidebar-link @(active == "Rooms" ? "active" : "")"
         asp-controller="Landlord" asp-action="Rooms">
        <i class="bi bi-door-open"></i><span>@Localizer["Phòng"]</span>
      </a>
      <a class="sidebar-link @(active == "FeeConfigs" ? "active" : "")"
         asp-controller="Landlord" asp-action="FeeConfigs">
        <i class="bi bi-sliders"></i><span>@Localizer["Cấu hình phí"]</span>
      </a>
      <div class="sidebar-section-label mt-3">@Localizer["Nghiệp vụ"]</div>
      <a class="sidebar-link @(active == "ViewingRequests" ? "active" : "")"
         asp-controller="Landlord" asp-action="ViewingRequests">
        <i class="bi bi-calendar-check"></i><span>@Localizer["Lịch hẹn xem"]</span>
      </a>
      <a class="sidebar-link @(active == "BookingRequests" ? "active" : "")"
         asp-controller="Landlord" asp-action="BookingRequests">
        <i class="bi bi-bookmark-check"></i><span>@Localizer["Đặt phòng"]</span>
      </a>
      <a class="sidebar-link @(active == "Contracts" ? "active" : "")"
         asp-controller="Landlord" asp-action="Contracts">
        <i class="bi bi-file-earmark-text"></i><span>@Localizer["Hợp đồng"]</span>
      </a>
      <a class="sidebar-link @(active == "Invoices" ? "active" : "")" href="#">
        <i class="bi bi-receipt"></i><span>@Localizer["Hoá đơn"]</span>
      </a>
    </nav>
  </div>
</div>

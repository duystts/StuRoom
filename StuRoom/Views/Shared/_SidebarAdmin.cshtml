@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    var active = ViewData["ActiveMenu"]?.ToString() ?? "";
}

<aside class="sturoom-sidebar" id="adminSidebar">
  <nav>
    <div class="sidebar-section-label">@Localizer["Tổng quan"]</div>

    <a class="sidebar-link @(active == "AdminDashboard" ? "active" : "")"
       asp-controller="Admin" asp-action="Dashboard">
      <i class="bi bi-bar-chart-line"></i>
      <span>@Localizer["Trang tổng quan"]</span>
    </a>

    <div class="sidebar-section-label mt-3">@Localizer["Quản trị"]</div>

    <a class="sidebar-link @(active == "ApproveLandlord" ? "active" : "")"
       asp-controller="Admin" asp-action="LandlordApproval">
      <i class="bi bi-person-check"></i>
      <span>@Localizer["Duyệt Landlord"]</span>
    </a>

    <a class="sidebar-link @(active == "Amenities" ? "active" : "")"
       asp-controller="Admin" asp-action="Amenities">
      <i class="bi bi-tags"></i>
      <span>@Localizer["Tiện ích"]</span>
    </a>

    <a class="sidebar-link @(active == "ReviewModeration" ? "active" : "")"
       asp-controller="Admin" asp-action="ReviewModeration">
      <i class="bi bi-star-half"></i>
      <span>@Localizer["Kiểm duyệt Review"]</span>
    </a>

    <a class="sidebar-link @(active == "Reports" ? "active" : "")"
       asp-controller="Admin" asp-action="Reports">
      <i class="bi bi-exclamation-triangle"></i>
      <span>@Localizer["Báo cáo vi phạm"]</span>
    </a>

    <div class="sidebar-section-label mt-3">@Localizer["Hệ thống"]</div>

    <a class="sidebar-link @(active == "AllUsers" ? "active" : "")" href="#">
      <i class="bi bi-people"></i>
      <span>@Localizer["Người dùng"]</span>
    </a>
  </nav>
</aside>

@* Mobile offcanvas *@
<button class="sturoom-sidebar-toggle d-lg-none"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#mobileAdminSidebar"
        aria-label="Mở menu">
  <i class="bi bi-layout-sidebar"></i>
</button>

<div class="offcanvas offcanvas-start sturoom-offcanvas" tabindex="-1" id="mobileAdminSidebar">
  <div class="offcanvas-header border-bottom">
    <span class="fw-bold" style="color:#6c8fff;font-size:18px">Stu<span style="color:#fff">Room</span>
      <small class="text-muted ms-2" style="font-size:12px">Admin</small>
    </span>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body p-0">
    <nav>
      <div class="sidebar-section-label">@Localizer["Tổng quan"]</div>
      <a class="sidebar-link @(active == "AdminDashboard" ? "active" : "")"
         asp-controller="Admin" asp-action="Dashboard">
        <i class="bi bi-bar-chart-line"></i><span>@Localizer["Trang tổng quan"]</span>
      </a>
      <div class="sidebar-section-label mt-3">@Localizer["Quản trị"]</div>
      <a class="sidebar-link @(active == "ApproveLandlord" ? "active" : "")"
         asp-controller="Admin" asp-action="LandlordApproval">
        <i class="bi bi-person-check"></i><span>@Localizer["Duyệt Landlord"]</span>
      </a>
      <a class="sidebar-link @(active == "Amenities" ? "active" : "")"
         asp-controller="Admin" asp-action="Amenities">
        <i class="bi bi-tags"></i><span>@Localizer["Tiện ích"]</span>
      </a>
      <a class="sidebar-link @(active == "ReviewModeration" ? "active" : "")"
         asp-controller="Admin" asp-action="ReviewModeration">
        <i class="bi bi-star-half"></i><span>@Localizer["Kiểm duyệt Review"]</span>
      </a>
      <a class="sidebar-link @(active == "Reports" ? "active" : "")"
         asp-controller="Admin" asp-action="Reports">
        <i class="bi bi-exclamation-triangle"></i><span>@Localizer["Báo cáo vi phạm"]</span>
      </a>
      <div class="sidebar-section-label mt-3">@Localizer["Hệ thống"]</div>
      <a class="sidebar-link @(active == "AllUsers" ? "active" : "")" href="#">
        <i class="bi bi-people"></i><span>@Localizer["Người dùng"]</span>
      </a>
    </nav>
  </div>
</div>

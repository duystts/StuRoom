@model List<StuRoom.Models.ViewingRequest>
@using StuRoom.Models
@{
    ViewData["Title"] = "Lịch hẹn xem phòng";

    var statusMap = new Dictionary<ViewingStatus, (string label, string css, string icon)>
    {
        [ViewingStatus.Pending]     = ("Đang chờ",   "bg-warning-subtle text-warning border border-warning-subtle",   "bi-hourglass-split"),
        [ViewingStatus.Confirmed]   = ("Đã xác nhận","bg-success-subtle text-success border border-success-subtle",   "bi-check-circle"),
        [ViewingStatus.Rescheduled] = ("Đổi giờ",    "bg-info-subtle text-info border border-info-subtle",           "bi-arrow-repeat"),
        [ViewingStatus.Cancelled]   = ("Đã huỷ",     "bg-danger-subtle text-danger border border-danger-subtle",     "bi-x-circle"),
        [ViewingStatus.Completed]   = ("Hoàn thành", "bg-secondary-subtle text-secondary border border-secondary-subtle","bi-check-all"),
    };
}

<div class="container py-4">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="fw-bold mb-0">Lịch hẹn xem phòng</h4>
      <p class="text-muted small mb-0">Danh sách lịch hẹn bạn đã đặt</p>
    </div>
    <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-search me-1"></i>Tìm phòng mới
    </a>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show py-2 small">
      <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  @if (!Model.Any())
  {
    <div class="text-center py-5 text-muted">
      <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
      Bạn chưa có lịch hẹn nào.
      <div class="mt-2">
        <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary btn-sm">
          Tìm phòng và đặt lịch
        </a>
      </div>
    </div>
  }
  else
  {
    <div class="row g-3">
      @foreach (var v in Model)
      {
        var (lbl, css, icon) = statusMap[v.Status];
        var img = v.Room.Images?.FirstOrDefault(i => i.IsPrimary)
               ?? v.Room.Images?.OrderBy(i => i.SortOrder).FirstOrDefault();
        <div class="col-md-6 col-xl-4">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex align-items-start gap-3 mb-3">
                @if (img != null)
                {
                  <img src="@img.ImageUrl" class="rounded-2 flex-shrink-0"
                       style="width:64px;height:64px;object-fit:cover" alt="room" />
                }
                else
                {
                  <div class="rounded-2 bg-light d-flex align-items-center justify-content-center flex-shrink-0"
                       style="width:64px;height:64px">
                    <i class="bi bi-door-open text-muted fs-4"></i>
                  </div>
                }
                <div class="flex-grow-1 min-w-0">
                  <div class="fw-bold text-truncate">Phòng @v.Room.RoomNumber</div>
                  <div class="text-muted small text-truncate">@v.Room.Building.Name</div>
                  <span class="badge @css mt-1" style="font-size:11px">
                    <i class="bi @icon me-1"></i>@lbl
                  </span>
                </div>
              </div>

              <div class="small mb-1">
                <i class="bi bi-clock me-1 text-muted"></i>
                <span class="fw-semibold">Đề xuất:</span>
                @v.ProposedTime.ToString("HH:mm — dd/MM/yyyy")
              </div>

              @if (v.ConfirmedTime.HasValue)
              {
                <div class="small mb-1 @(v.Status == ViewingStatus.Rescheduled ? "text-info" : "text-success")">
                  <i class="bi bi-calendar-check me-1"></i>
                  <span class="fw-semibold">
                    @(v.Status == ViewingStatus.Rescheduled ? "Giờ mới đề xuất:" : "Đã xác nhận:")
                  </span>
                  @v.ConfirmedTime.Value.ToString("HH:mm — dd/MM/yyyy")
                </div>
              }

              @if (!string.IsNullOrWhiteSpace(v.TenantNote))
              {
                <div class="small text-muted mt-1">
                  <i class="bi bi-chat-left-text me-1"></i>@v.TenantNote
                </div>
              }

              @if (!string.IsNullOrWhiteSpace(v.LandlordNote))
              {
                <div class="small mt-1 p-2 bg-light rounded">
                  <i class="bi bi-person me-1 text-primary"></i>
                  <span class="text-muted">Chủ trọ:</span> @v.LandlordNote
                </div>
              }

              @if (v.Status == ViewingStatus.Pending || v.Status == ViewingStatus.Confirmed)
              {
                <div class="mt-3 pt-2 border-top">
                  <form asp-action="Cancel" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@v.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Huỷ lịch hẹn này?')">
                      <i class="bi bi-x-circle me-1"></i>Huỷ lịch
                    </button>
                  </form>
                </div>
              }
              else if (v.Status == ViewingStatus.Rescheduled)
              {
                <div class="mt-3 pt-2 border-top d-flex gap-2">
                  <form asp-action="AcceptReschedule" method="post" class="d-inline flex-grow-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@v.Id" />
                    <button type="submit" class="btn btn-sm btn-success w-100">
                      <i class="bi bi-check-circle me-1"></i>Chấp nhận
                    </button>
                  </form>
                  <form asp-action="DeclineReschedule" method="post" class="d-inline flex-grow-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@v.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                            onclick="return confirm('Bạn muốn từ chối giờ hẹn mới và huỷ lịch này?')">
                      <i class="bi bi-x-circle me-1"></i>Không chấp nhận
                    </button>
                  </form>
                </div>
              }
            </div>
          </div>
        </div>
      }
    </div>
  }

</div>

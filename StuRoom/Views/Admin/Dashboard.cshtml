@model StuRoom.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="mb-4">
  <h4 class="fw-bold mb-0">Dashboard</h4>
  <p class="text-muted small mb-0">Tổng quan toàn hệ thống StuRoom</p>
</div>

@* ── Stat cards ── *@
<div class="row g-3 mb-4">

  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#ede9fe">
          <i class="bi bi-door-open fs-4" style="color:#7c3aed"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1">@Model.TotalRooms</div>
          <div class="text-muted small">Tổng phòng</div>
          <div style="font-size:11px;color:#9ca3af">
            @Model.AvailableRooms trống · @Model.OccupiedRooms đã thuê
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#dbeafe">
          <i class="bi bi-people fs-4" style="color:#1d4ed8"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1">@Model.TotalUsers</div>
          <div class="text-muted small">Người dùng</div>
          <div style="font-size:11px;color:#9ca3af">
            @Model.TotalTenants tenant · @Model.TotalLandlords landlord
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#d1fae5">
          <i class="bi bi-file-earmark-text fs-4" style="color:#065f46"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1">@Model.ActiveContracts</div>
          <div class="text-muted small">Hợp đồng active</div>
          <div style="font-size:11px;color:#9ca3af">
            Tổng @Model.TotalContracts hợp đồng
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:48px;height:48px;background:#fef9c3">
          <i class="bi bi-cash-stack fs-4" style="color:#854d0e"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1">
            @Model.TotalRevenue.ToString("N0") <small class="fw-normal fs-6 text-muted">₫</small>
          </div>
          <div class="text-muted small">Doanh thu</div>
          <div style="font-size:11px;color:#9ca3af">Tổng thanh toán ghi nhận</div>
        </div>
      </div>
    </div>
  </div>

</div>

@* ── Action items ── *@
<div class="row g-3">

  @* Landlord chờ duyệt *@
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h6 class="fw-bold mb-0">Landlord chờ duyệt</h6>
          <a asp-action="LandlordApproval" class="btn btn-outline-primary btn-sm">Xem tất cả</a>
        </div>
        @if (Model.PendingLandlords == 0)
        {
          <p class="text-muted small mb-0">
            <i class="bi bi-check2-circle me-1 text-success"></i>Không có tài khoản nào chờ duyệt.
          </p>
        }
        else
        {
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">@Model.PendingLandlords</span>
            <span class="small text-muted">tài khoản đang chờ xét duyệt</span>
          </div>
        }
      </div>
    </div>
  </div>

  @* Review chờ duyệt *@
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h6 class="fw-bold mb-0">Review bị ẩn</h6>
          <a asp-action="ReviewModeration" asp-route-filter="hidden" class="btn btn-outline-primary btn-sm">Xem tất cả</a>
        </div>
        @if (Model.PendingReviews == 0)
        {
          <p class="text-muted small mb-0">
            <i class="bi bi-check2-circle me-1 text-success"></i>Không có review nào đang bị ẩn.
          </p>
        }
        else
        {
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-danger fs-6 px-3 py-2">@Model.PendingReviews</span>
            <span class="small text-muted">review đang bị ẩn</span>
          </div>
        }
      </div>
    </div>
  </div>

  @* Tỷ lệ Landlord *@
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h6 class="fw-bold mb-3">Landlord</h6>
        @if (Model.TotalLandlords > 0)
        {
          var pct = (int)Math.Round((double)Model.ActiveLandlords / Model.TotalLandlords * 100);
          <div class="d-flex justify-content-between small text-muted mb-1">
            <span>Đã duyệt</span>
            <span>@Model.ActiveLandlords / @Model.TotalLandlords (@pct%)</span>
          </div>
          <div class="progress" style="height:8px">
            <div class="progress-bar bg-success" style="width:@pct%"></div>
          </div>
        }
        else
        {
          <p class="text-muted small mb-0">Chưa có Landlord nào.</p>
        }
      </div>
    </div>
  </div>

  @* Tỷ lệ phòng *@
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h6 class="fw-bold mb-3">Tỷ lệ lấp đầy</h6>
        @if (Model.TotalRooms > 0)
        {
          var pct = (int)Math.Round((double)Model.OccupiedRooms / Model.TotalRooms * 100);
          <div class="d-flex justify-content-between small text-muted mb-1">
            <span>Đã thuê</span>
            <span>@Model.OccupiedRooms / @Model.TotalRooms (@pct%)</span>
          </div>
          <div class="progress" style="height:8px">
            <div class="progress-bar" style="width:@pct%;background:#6c8fff"></div>
          </div>
        }
        else
        {
          <p class="text-muted small mb-0">Chưa có phòng nào.</p>
        }
      </div>
    </div>
  </div>

</div>

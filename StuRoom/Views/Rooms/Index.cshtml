@model StuRoom.Models.ViewModels.RoomSearchViewModel
@{
    ViewData["Title"] = "Tìm phòng";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
  <div class="row g-4">

    @* ══════ Sidebar bộ lọc ══════ *@
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm sticky-top" style="top:70px">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="bi bi-funnel me-2"></i>Bộ lọc</h6>
          <form method="get" asp-action="Index" id="filterForm">

            @* Keyword *@
            <div class="mb-3">
              <label class="form-label small fw-semibold">Tìm kiếm</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="Q" class="form-control" placeholder="Tên tòa nhà, khu vực..."
                       value="@Model.Q" />
              </div>
            </div>

            @* Province *@
            @if (Model.Provinces.Any())
            {
              <div class="mb-3">
                <label class="form-label small fw-semibold">Tỉnh / Thành phố</label>
                <select name="Province" class="form-select form-select-sm"
                        onchange="document.getElementById('filterForm').submit()">
                  <option value="">Tất cả</option>
                  @foreach (var p in Model.Provinces)
                  {
                    if (Model.Province == p)
                    {
                      <option value="@p" selected>@p</option>
                    }
                    else
                    {
                      <option value="@p">@p</option>
                    }
                  }
                </select>
              </div>
            }

            @* District *@
            <div class="mb-3">
              <label class="form-label small fw-semibold">Quận / Huyện</label>
              <input type="text" name="District" class="form-control form-control-sm"
                     placeholder="VD: Thủ Đức" value="@Model.District" />
            </div>

            @* Price range *@
            <div class="mb-3">
              <label class="form-label small fw-semibold">Giá thuê (₫/tháng)</label>
              <div class="d-flex gap-2 align-items-center">
                <input type="number" name="MinPrice" class="form-control form-control-sm"
                       placeholder="Từ" value="@Model.MinPrice" min="0" step="100000" />
                <span class="text-muted small">—</span>
                <input type="number" name="MaxPrice" class="form-control form-control-sm"
                       placeholder="Đến" value="@Model.MaxPrice" min="0" step="100000" />
              </div>
            </div>

            @* Min area *@
            <div class="mb-3">
              <label class="form-label small fw-semibold">Diện tích tối thiểu (m²)</label>
              <input type="number" name="MinArea" class="form-control form-control-sm"
                     placeholder="VD: 15" value="@Model.MinArea" min="0" step="1" />
            </div>

            @* Amenities *@
            @if (Model.AllAmenities.Any())
            {
              <div class="mb-3">
                <label class="form-label small fw-semibold">Tiện ích</label>
                <div class="d-flex flex-column gap-1">
                  @foreach (var a in Model.AllAmenities)
                  {
                    <div class="form-check form-check-sm">
                      <input class="form-check-input" type="checkbox"
                             name="AmenityIds" value="@a.Id"
                             id="fa_@a.Id"
                             @(Model.AmenityIds.Contains(a.Id) ? "checked" : "") />
                      <label class="form-check-label small" for="fa_@a.Id">
                        <i class="bi @a.IconClass me-1"></i>@a.Name
                      </label>
                    </div>
                  }
                </div>
              </div>
            }

            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-search me-1"></i>Tìm phòng
              </button>
              <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i>Xoá bộ lọc
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>

    @* ══════ Danh sách phòng ══════ *@
    <div class="col-lg-9">

      @* Header *@
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h5 class="fw-bold mb-0">Phòng trống</h5>
          <p class="text-muted small mb-0">
            @if (Model.TotalCount == 0)
            {
              <span>Không tìm thấy phòng nào phù hợp</span>
            }
            else
            {
              <span>Tìm thấy <strong>@Model.TotalCount</strong> phòng</span>
            }
          </p>
        </div>
        @* Active filter chips *@
        <div class="d-flex flex-wrap gap-1">
          @if (!string.IsNullOrWhiteSpace(Model.Q))
          {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
              "@Model.Q"
            </span>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Province))
          {
            <span class="badge bg-info-subtle text-info border border-info-subtle">@Model.Province</span>
          }
          @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
          {
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
              @(Model.MinPrice.HasValue ? Model.MinPrice.Value.ToString("N0") + "₫" : "")
              @(Model.MinPrice.HasValue && Model.MaxPrice.HasValue ? " – " : "")
              @(Model.MaxPrice.HasValue ? Model.MaxPrice.Value.ToString("N0") + "₫" : "")
            </span>
          }
        </div>
      </div>

      @if (!Model.Rooms.Any())
      {
        <div class="text-center py-5 text-muted">
          <i class="bi bi-house-slash fs-1 d-block mb-3"></i>
          <h6>Không tìm thấy phòng nào</h6>
          <p class="small">Thử thay đổi bộ lọc hoặc <a asp-action="Index">xem tất cả phòng</a>.</p>
        </div>
      }
      else
      {
        <div class="row g-3">
          @foreach (var room in Model.Rooms)
          {
            <div class="col-sm-6 col-xl-4">
              <a asp-action="Detail" asp-route-id="@room.Id"
                 class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm h-100 room-card">

                  @* Image *@
                  <div class="position-relative">
                    @if (room.PrimaryImageUrl != null)
                    {
                      <img src="@room.PrimaryImageUrl" alt="@room.BuildingName"
                           class="card-img-top"
                           style="height:180px;object-fit:cover" />
                    }
                    else
                    {
                      <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                           style="height:180px">
                        <i class="bi bi-image text-muted fs-1"></i>
                      </div>
                    }

                    @* Badges *@
                    <div class="position-absolute top-0 start-0 m-2 d-flex flex-column gap-1">
                      @if (room.Capacity is > 1)
                      {
                        <span class="badge bg-success" style="font-size:10px">
                          <i class="bi bi-people-fill me-1"></i>Tìm ghép
                        </span>
                      }
                    </div>

                    @* Price badge *@
                    @if (room.RentPrice.HasValue)
                    {
                      <div class="position-absolute bottom-0 end-0 m-2">
                        <span class="badge bg-dark bg-opacity-75 fs-6 fw-bold px-2 py-1">
                          @room.RentPrice.Value.ToString("N0")
                          <small class="fw-normal" style="font-size:10px">₫/@room.RentUnit</small>
                        </span>
                      </div>
                    }
                  </div>

                  <div class="card-body py-2 px-3">
                    <h6 class="fw-bold mb-0 text-truncate">@room.BuildingName</h6>
                    <div class="text-muted small text-truncate mb-1">
                      <i class="bi bi-geo-alt me-1"></i>@room.Address
                      @if (!string.IsNullOrWhiteSpace(room.District))
                      {
                        <span>, @room.District</span>
                      }
                    </div>

                    <div class="d-flex gap-3 small text-muted mb-2">
                      <span><i class="bi bi-rulers me-1"></i>@room.Area m²</span>
                      @if (room.Capacity.HasValue)
                      {
                        <span><i class="bi bi-people me-1"></i>@room.Capacity người</span>
                      }
                    </div>

                    @* Amenity icons *@
                    @if (room.Amenities.Any())
                    {
                      <div class="d-flex flex-wrap gap-1 mb-2">
                        @foreach (var (icon, name) in room.Amenities.Take(5))
                        {
                          <span class="badge bg-light text-secondary border" title="@name" style="font-size:11px">
                            <i class="bi @icon"></i>
                          </span>
                        }
                        @if (room.Amenities.Count > 5)
                        {
                          <span class="badge bg-light text-secondary border" style="font-size:11px">
                            +@(room.Amenities.Count - 5)
                          </span>
                        }
                      </div>
                    }

                    @* Rating *@
                    @if (room.ReviewCount > 0)
                    {
                      <div class="d-flex align-items-center gap-1 small">
                        <i class="bi bi-star-fill" style="color:#f59e0b;font-size:11px"></i>
                        <span class="fw-semibold">@room.AvgRating!.Value.ToString("0.0")</span>
                        <span class="text-muted">(@room.ReviewCount đánh giá)</span>
                      </div>
                    }
                    else
                    {
                      <div class="small text-muted">Chưa có đánh giá</div>
                    }
                  </div>

                </div>
              </a>
            </div>
          }
        </div>
      }
    </div>

  </div>
</div>

@section Styles {
<style>
  .room-card { transition: transform .15s, box-shadow .15s; cursor: pointer; }
  .room-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.12) !important; }
</style>
}

@model StuRoom.Models.ViewModels.RoomSearchViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Tìm phòng"];
    Layout = "_Layout";
}

<div class="container-fluid py-5">
@* Hidden form for AJAX anti-forgery token *@
@Html.AntiForgeryToken()
  <div class="row g-4">

    @* ══════ Sidebar bộ lọc (Sticky) ══════ *@
    <div class="col-lg-3">
      <div class="card filter-card sticky-top" style="top:90px; z-index: 100;">
        <div class="card-body p-4">
          <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
            <h6 class="fw-bold mb-0 text-dark filter-title"><i class="bi bi-funnel me-2 text-primary"></i>@Localizer["Bộ lọc"]</h6>
            <a asp-action="Index" class="text-decoration-none text-primary small fw-semibold">@Localizer["Xóa tất cả"]</a>
          </div>
          
          <form method="get" asp-action="Index" id="filterForm">
            @* Keyword *@
            <div class="mb-4">
              <label class="form-label small fw-semibold text-secondary">@Localizer["Tìm kiếm"]</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-white border-end-0 border-radius-custom" style="border-top-left-radius: 12px; border-bottom-left-radius: 12px;"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="Q" class="form-control form-control-custom border-start-0" 
                       style="border-top-left-radius: 0; border-bottom-left-radius: 0;"
                       placeholder="@Localizer["Tên tòa nhà, khu vực..."]" value="@Model.Q" />
              </div>
            </div>

            @* Province *@
            @if (Model.Provinces.Any())
            {
              <div class="mb-4">
                <label class="form-label small fw-semibold text-secondary">@Localizer["Tỉnh / Thành phố"]</label>
                <select name="Province" class="form-select form-control-custom"
                        onchange="$('#filterForm').submit()">
                  <option value="">@Localizer["Tất cả"]</option>
                  @foreach (var p in Model.Provinces)
                  {
                    if (Model.Province == p)
                    {
                      <option value="@p" selected>@p</option>
                    }
                    else
                    {
                      <option value="@p">@p</option>
                    }
                  }
                </select>
              </div>
            }

            @* District *@
            <div class="mb-4">
              <label class="form-label small fw-semibold text-secondary">@Localizer["Quận / Huyện"]</label>
              <input type="text" name="District" class="form-control form-control-custom"
                     placeholder="@Localizer["VD: Thủ Đức"]" value="@Model.District" />
            </div>

            @* Max price range slider *@
            <div class="mb-4">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <label class="form-label small fw-semibold text-secondary mb-0">@Localizer["Mức giá tối đa"]</label>
                <span id="priceDisplay" class="text-primary fw-bold small">@(Model.MaxPrice.HasValue ? (Model.MaxPrice.Value / 1000000.0m).ToString("0.#") + " " + Localizer["Tr"].Value : Localizer["10 Tr+"].Value)</span>
              </div>
              <input type="range" name="MaxPrice" id="priceSlider" class="form-range custom-range"
                     min="1000000" max="10000000" step="500000" value="@(Model.MaxPrice ?? 10000000)" />
              <div class="d-flex justify-content-between small text-muted mt-1" style="font-size: 11px;">
                <span>1 @Localizer["Tr"]</span>
                <span>@Localizer["10 Tr+"]</span>
              </div>
            </div>

            @* Min area *@
            <div class="mb-4">
              <label class="form-label small fw-semibold text-secondary">@Localizer["Diện tích tối thiểu (m²)"]</label>
              <input type="number" name="MinArea" class="form-control form-control-custom"
                     placeholder="@Localizer["VD: 15"]" value="@Model.MinArea" min="0" step="1" />
            </div>

            @* Amenities *@
            @if (Model.AllAmenities.Any())
            {
              <div class="mb-4">
                <label class="form-label small fw-semibold text-secondary mb-2 d-block">@Localizer["Tiện ích cơ bản"]</label>
                <div class="d-flex flex-column gap-2" style="max-height: 200px; overflow-y: auto;">
                  @foreach (var a in Model.AllAmenities)
                  {
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox"
                             name="AmenityIds" value="@a.Id"
                             id="fa_@a.Id"
                             @(Model.AmenityIds.Contains(a.Id) ? "checked" : "") />
                      <label class="form-check-label small text-dark" style="cursor: pointer;" for="fa_@a.Id">
                        <i class="bi @a.IconClass me-1.5 text-muted"></i>@a.Name
                      </label>
                    </div>
                  }
                </div>
              </div>
            }

            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary rounded-pill py-2 small fw-semibold shadow-sm">
                <i class="bi bi-search me-1.5"></i>@Localizer["Tìm phòng"]
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    @* ══════ Danh sách phòng ══════ *@
    <div class="col-lg-9" id="roomListContainer">

      @* Header *@
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <h4 class="fw-bold mb-1 text-dark">@Localizer["Phòng trọ tại"] @(string.IsNullOrEmpty(Model.Province) ? "TP.HCM" : Model.Province)</h4>
          <p class="text-muted small mb-0">
            @if (Model.TotalCount == 0)
            {
              <span>@Localizer["Không tìm thấy phòng nào phù hợp"]</span>
            }
            else
            {
              <span>@Localizer["Hiển thị"] <strong>@Model.TotalCount</strong> @Localizer["kết quả phù hợp"]</span>
            }
          </p>
        </div>

        @* Right actions: Map view mock and sort dropdown *@
        <div class="d-flex gap-2">
          @{
            var mapQuery = "Thành phố Hồ Chí Minh";
            if (!string.IsNullOrEmpty(Model.Province))
            {
              mapQuery = Model.Province;
            }
            if (!string.IsNullOrEmpty(Model.Q))
            {
              mapQuery = Model.Q + ", " + mapQuery;
            }
          }
          <a href="https://www.google.com/maps/search/?api=1&query=@System.Net.WebUtility.UrlEncode(mapQuery)" 
             target="_blank"
             class="btn btn-outline-secondary btn-sm rounded-pill px-3 py-1.5 fw-semibold border bg-white d-flex align-items-center gap-1.5 shadow-sm text-secondary text-decoration-none">
            <i class="bi bi-map"></i>@Localizer["Bản đồ"]
          </a>
          <select class="form-select form-select-sm rounded-pill px-3 py-1.5 fw-semibold border bg-white text-secondary shadow-sm" style="width: auto; cursor: pointer;">
            <option>@Localizer["Mới nhất"]</option>
            <option>@Localizer["Giá tăng dần"]</option>
            <option>@Localizer["Giá giảm dần"]</option>
          </select>
        </div>
      </div>

      @* Active Filter Chips *@
      @if (!string.IsNullOrWhiteSpace(Model.Q) || !string.IsNullOrWhiteSpace(Model.Province) || Model.MinPrice.HasValue || Model.MaxPrice.HasValue || Model.MinArea.HasValue || Model.AmenityIds.Any())
      {
        <div class="d-flex flex-wrap gap-1.5 mb-4 align-items-center">
          <span class="text-muted small me-1">@Localizer["Bộ lọc đang áp dụng:"]</span>
          @if (!string.IsNullOrWhiteSpace(Model.Q))
          {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2.5 py-1.5 font-monospace">
              "@Model.Q"
            </span>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Province))
          {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2.5 py-1.5">@Model.Province</span>
          }
          @if (Model.MaxPrice.HasValue)
          {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2.5 py-1.5">
              @Localizer["Dưới"] @((Model.MaxPrice.Value / 1000000.0m).ToString("0.#")) @Localizer["Tr ₫"]
            </span>
          }
          @if (Model.MinArea.HasValue)
          {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2.5 py-1.5">
              @Localizer["Diện tích"] ≥ @Model.MinArea m²
            </span>
          }
          <a asp-action="Index" class="text-decoration-none text-muted small ms-2"><i class="bi bi-x-circle me-1"></i>@Localizer["Xóa hết"]</a>
        </div>
      }

      @if (!Model.Rooms.Any())
      {
        <div class="text-center py-5 bg-white rounded-3 shadow-sm my-4 border">
          <i class="bi bi-house-slash text-muted fs-1 d-block mb-3"></i>
          <h5 class="text-dark fw-bold">@Localizer["Không tìm thấy phòng nào"]</h5>
          <p class="text-muted small">@Localizer["Thử thay đổi bộ lọc hoặc xóa bộ lọc để xem tất cả phòng."]</p>
          <a asp-action="Index" class="btn btn-primary rounded-pill btn-sm px-4 fw-semibold mt-2 shadow-sm">@Localizer["Xem tất cả"]</a>
        </div>
      }
      else
      {
        <div class="row g-4">
          @foreach (var room in Model.Rooms)
          {
            // Dynamic category label based on capacity and area
            var categoryLabel = Localizer["Phòng trọ"].Value;
            if (room.Capacity == 1) { categoryLabel = Localizer["Ký túc xá"].Value; }
            else if (room.Area > 25 && room.Capacity <= 2) { categoryLabel = Localizer["Phòng Studio"].Value; }
            else if (room.Area > 40) { categoryLabel = Localizer["Căn hộ"].Value; }

            <div class="col-sm-6 col-xl-4">
              <a asp-action="Detail" asp-route-id="@room.Id" class="text-decoration-none text-dark">
                <div class="card border-0 shadow-sm h-100 room-card">

                  @* Image & Badges *@
                  <div class="position-relative overflow-hidden card-img-wrapper" style="height: 200px;">
                    @if (room.PrimaryImageUrl != null)
                    {
                      <img src="@room.PrimaryImageUrl" alt="@room.BuildingName"
                           class="w-100 h-100 room-card-img" style="object-fit:cover" />
                    }
                    else
                    {
                      <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                        <i class="bi bi-image text-muted fs-1"></i>
                      </div>
                    }

                    @* Badges *@
                    <div class="position-absolute top-0 start-0 m-3 d-flex gap-2" style="z-index: 2;">
                      @if (room.AvgRating >= 4.5 || room.ReviewCount > 2)
                      {
                        <span class="badge badge-featured">@Localizer["Nổi bật"]</span>
                      }
                      <span class="badge badge-category">@categoryLabel</span>
                    </div>

                    @* Favorite heart icon *@
                    @{
                      bool isFav = ViewBag.FavoriteRoomIds != null && ((List<int>)ViewBag.FavoriteRoomIds).Contains(room.Id);
                    }
                    <button type="button" class="btn btn-fav @(isFav ? "active" : "") position-absolute top-0 end-0 m-3 d-flex align-items-center justify-content-center shadow-sm"
                            style="z-index: 2;"
                            onclick="handleFavToggle(event, @room.Id, this)">
                      <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                    </button>
                  </div>

                  @* Details *@
                  <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                      <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                        <h6 class="fw-bold mb-0 text-truncate text-dark card-room-title">@room.BuildingName - P.@room.RoomNumber</h6>
                        @if (room.ReviewCount > 0)
                        {
                          <span class="badge badge-rating d-inline-flex align-items-center gap-1">
                            @room.AvgRating!.Value.ToString("0.0") <i class="bi bi-star-fill text-warning" style="font-size: 10px;"></i>
                          </span>
                        }
                      </div>
                      
                      <div class="text-muted small text-truncate mb-3">
                        <i class="bi bi-geo-alt me-1"></i>@room.Address
                        @if (!string.IsNullOrWhiteSpace(room.District))
                        {
                          <span>, @room.District</span>
                        }
                      </div>

                      <div class="d-flex flex-wrap gap-1.5 mb-3">
                        <span class="badge badge-spec"><i class="bi bi-rulers me-1"></i>@room.Area m²</span>
                        @if (room.Capacity.HasValue)
                        {
                          <span class="badge badge-spec"><i class="bi bi-people me-1"></i>@room.Capacity @Localizer["người"]</span>
                        }
                        @foreach (var (icon, name) in room.Amenities.Take(3))
                        {
                          <span class="badge badge-spec-icon" title="@name"><i class="bi @icon"></i></span>
                        }
                      </div>
                    </div>

                    @* Footer *@
                    <div class="d-flex align-items-center justify-content-between pt-3 border-top">
                      <div>
                        <span class="text-muted text-uppercase fw-semibold d-block" style="font-size: 9px; letter-spacing: 0.05em; margin-bottom: 2.5px;">@Localizer["Giá thuê"]</span>
                        @if (room.RentPrice.HasValue)
                        {
                          <div class="card-room-price mb-0">
                            <span class="price-value">@((room.RentPrice.Value / 1000000.0m).ToString("0.#"))</span> <span class="price-unit">@Localizer["Tr"]</span><span class="price-period">/@Localizer["tháng"]</span>
                          </div>
                        }
                        else
                        {
                          <div class="text-muted small fw-semibold">@Localizer["Liên hệ"]</div>
                        }
                      </div>
                      <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-sm btn-compare rounded-pill px-2.5 py-1" data-room-id="@room.Id"
                                onclick="toggleCompareRoom(event, @room.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(room.BuildingName)) - P.@room.RoomNumber', '@((room.RentPrice ?? 0) / 1000000.0m).ToString("0.#") ' + '@Localizer["Tr/tháng"]', '@room.PrimaryImageUrl')">
                          <i class="bi bi-shuffle me-1"></i><span class="compare-text">@Localizer["So sánh"]</span>
                        </button>
                        <div class="btn-detail-arrow d-flex align-items-center justify-content-center">
                          <i class="bi bi-arrow-right"></i>
                        </div>
                      </div>
                    </div>
                  </div>

                </div>
              </a>
            </div>
          }
        </div>
      }
    </div>

  </div>
</div>

@section Styles {
<style>
  /* General page styles */
  .container-fluid {
    max-width: 1400px;
    padding-left: 2rem;
    padding-right: 2rem;
  }
</style>
}

@section Scripts {
<script>
  // Price slider dynamics
  const priceSlider = document.getElementById('priceSlider');
  const priceDisplay = document.getElementById('priceDisplay');
  
  if (priceSlider && priceDisplay) {
    const tenTrPlusText = '@Localizer["10 Tr+"]';
    const trText = '@Localizer["Tr"]';
    priceSlider.addEventListener('input', function() {
      const val = parseFloat(this.value);
      if (val >= 10000000) {
        priceDisplay.textContent = tenTrPlusText;
      } else {
        priceDisplay.textContent = (val / 1000000).toFixed(1) + ' ' + trText;
      }
    });

    // Auto submit on slider release to trigger query filtering
    priceSlider.addEventListener('change', function() {
      $('#filterForm').submit();
    });
  }

  // AJAX Filter submission & Skeleton loader
  function showSkeletons() {
    let skeletonsHtml = `
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <div class="skeleton-title" style="width: 250px; height: 28px;"></div>
          <div class="skeleton-text-short" style="width: 150px; height: 14px; margin-top: 6px; margin-bottom: 0;"></div>
        </div>
        <div class="d-flex gap-2">
          <div class="skeleton-badge" style="width: 100px; height: 38px; border-radius: 20px;"></div>
          <div class="skeleton-badge" style="width: 120px; height: 38px; border-radius: 20px;"></div>
        </div>
      </div>
      <div class="row g-4">
    `;
    
    for (let i = 0; i < 6; i++) {
      skeletonsHtml += `
        <div class="col-sm-6 col-xl-4">
          <div class="card border-0 shadow-sm h-100 skeleton-card">
            <div class="skeleton-img"></div>
            <div class="card-body p-4 d-flex flex-column justify-content-between" style="min-height: 240px;">
              <div>
                <div class="skeleton-title"></div>
                <div class="skeleton-text-short"></div>
                <div class="d-flex gap-2 mb-3">
                  <div class="skeleton-badge"></div>
                  <div class="skeleton-badge"></div>
                  <div class="skeleton-badge"></div>
                </div>
              </div>
              <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                <div class="skeleton-price"></div>
                <div class="skeleton-button"></div>
              </div>
            </div>
          </div>
        </div>
      `;
    }
    
    skeletonsHtml += `</div>`;
    $('#roomListContainer').html(skeletonsHtml);
  }

  function loadRoomsList(url, pushState = true) {
    showSkeletons();
    
    $.ajax({
      url: url,
      type: 'GET',
      success: function(html) {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const newContent = doc.getElementById('roomListContainer');
        
        if (newContent) {
          $('#roomListContainer').html($(newContent).html());
          
          if (pushState) {
            history.pushState(null, '', url);
          }
          
          // Trigger global compare sync
          if (typeof syncCompareButtons === 'function') {
            syncCompareButtons();
          }
        }
      },
      error: function() {
        showToast("Không thể tải danh sách phòng. Vui lòng thử lại.", "error");
        window.location.href = url;
      }
    });
  }

  // Intercept form submission
  $('#filterForm').on('submit', function(e) {
    e.preventDefault();
    const url = $(this).attr('action') + '?' + $(this).serialize();
    loadRoomsList(url, true);
  });

  // Intercept reset and clear filter links
  $(document).on('click', 'a[href="/Rooms"], a[href^="/Rooms?"], a[href^="/Rooms/Index"]', function(e) {
    const href = $(this).attr('href');
    if (href.includes('/Detail/') || $(this).attr('target') === '_blank') {
      return;
    }
    e.preventDefault();
    loadRoomsList(href, true);
  });

  // Listen to popstate for back/forward support
  window.addEventListener('popstate', function() {
    loadRoomsList(window.location.href, false);
  });

  // Favorite toggle logic (AJAX)
  function handleFavToggle(e, roomId, btn) {
    e.preventDefault();
    e.stopPropagation();
    
    @if (!User.Identity!.IsAuthenticated)
    {
      <text>
      if (confirm("@Localizer["Bạn cần đăng nhập để lưu phòng yêu thích. Đăng nhập ngay?"]")) {
        window.location.href = '@Url.Page("/Account/Login", new { area = "Identity" })?returnUrl=' + encodeURIComponent('@Context.Request.Path' + '?autoFav=' + roomId);
      }
      </text>
    }
    else
    {
      <text>
      $.ajax({
        url: '@Url.Action("ToggleFavorite", "Rooms")',
        type: 'POST',
        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
        data: { roomId: roomId },
        success: function(response) {
          if (response.success) {
            btn.classList.add('animating');
            setTimeout(() => btn.classList.remove('animating'), 500);
            
            const heart = btn.querySelector('i');
            if (response.isFavorite) {
              btn.classList.add('active');
              heart.className = 'bi bi-heart-fill text-danger';
              showToast("@Localizer["Đã lưu vào danh sách yêu thích!"]", "success");
            } else {
              btn.classList.remove('active');
              heart.className = 'bi bi-heart';
              showToast("@Localizer["Đã xoá khỏi danh sách yêu thích!"]", "info");
            }
          }
        },
        error: function() {
          showToast("@Localizer["Có lỗi xảy ra, vui lòng thử lại sau."]", "error");
        }
      });
      </text>
    }
  }

  // Auto-favorite after login redirect
  @if (User.Identity!.IsAuthenticated)
  {
    <text>
  const urlParams = new URLSearchParams(window.location.search);
  const autoFavId = parseInt(urlParams.get('autoFav'));
  if (autoFavId) {
    const favBtn = document.querySelector(`[onclick*="handleFavToggle(event, ${autoFavId},"]`);
    if (favBtn) {
      // Remove query param from URL without reload
      const newUrl = window.location.pathname + window.location.search.replace(/[?&]autoFav=\d+/, '').replace(/^&/, '?');
      history.replaceState(null, '', newUrl || window.location.pathname);
      // Trigger the favorite
      $.ajax({
        url: '@Url.Action("ToggleFavorite", "Rooms")',
        type: 'POST',
        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
        data: { roomId: autoFavId },
        success: function(response) {
          if (response.success && response.isFavorite && favBtn) {
            favBtn.classList.add('active');
            const heart = favBtn.querySelector('i');
            if (heart) heart.className = 'bi bi-heart-fill text-danger';
          }
        }
      });
    }
  }
    </text>
  }
</script>
}

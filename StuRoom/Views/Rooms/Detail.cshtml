@section Scripts {
<script>
// Star picker logic
const stars = document.querySelectorAll('.star-btn');
const ratingInput = document.getElementById('ratingInput');
if (stars.length) {
  stars.forEach(star => {
    star.addEventListener('mouseover', () => highlightStars(+star.dataset.val));
    star.addEventListener('mouseout',  () => highlightStars(+(ratingInput?.value || 0)));
    star.addEventListener('click',     () => {
      ratingInput.value = star.dataset.val;
      highlightStars(+star.dataset.val);
    });
  });
}
function highlightStars(n) {
  stars.forEach(s => {
    const v = +s.dataset.val;
    s.className = v <= n
      ? 'bi bi-star-fill fs-3 star-btn'
      : 'bi bi-star fs-3 star-btn';
    s.style.color = v <= n ? '#f59e0b' : '#cbd5e1';
  });
}

function toggleDetailFav(roomId) {
  @if (!User.Identity!.IsAuthenticated)
  {
    <text>
    if (confirm("@Localizer["Bạn cần đăng nhập để lưu phòng yêu thích. Đăng nhập ngay?"]")) {
      window.location.href = '@Url.Page("/Account/Login", new { area = "Identity", returnUrl = Context.Request.Path })';
    }
    </text>
  }
  else
  {
    <text>
    const btn = document.getElementById('detailFavBtn');
    const text = document.getElementById('favText');
    const icon = btn.querySelector('i');
    
    $.ajax({
      url: '@Url.Action("ToggleFavorite", "Rooms")',
      type: 'POST',
      headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
      data: { roomId: roomId },
      success: function(response) {
        if (response.success) {
          btn.classList.add('animating');
          setTimeout(() => btn.classList.remove('animating'), 500);
          
          if (response.isFavorite) {
            btn.classList.add('active');
            icon.className = 'bi bi-heart-fill text-danger';
            text.textContent = "@Localizer["Đã lưu"]";
            showToast("@Localizer["Đã lưu vào danh sách yêu thích!"]", "success");
          } else {
            btn.classList.remove('active');
            icon.className = 'bi bi-heart';
            text.textContent = "@Localizer["Lưu tin"]";
            showToast("@Localizer["Đã xoá khỏi danh sách yêu thích!"]", "info");
          }
        }
      },
      error: function() {
        showToast("@Localizer["Có lỗi xảy ra, vui lòng thử lại sau."]", "error");
      }
    });
    </text>
  }
}

// Logic for report reason chips and input validation
document.addEventListener("DOMContentLoaded", function() {
  const reasonInput = document.getElementById('reportReasonInput');
  const reasonHelp = document.getElementById('reasonHelpText');
  const descInput = document.getElementById('reportDescInput');
  const descWarning = document.getElementById('reportDescWarning');
  const charCount = document.getElementById('reportCharCount');
  const submitBtn = document.getElementById('btnSubmitReport');
  const chips = document.querySelectorAll('.report-reason-chip');
  
  const helpTexts = {
    'Fraud': 'Báo cáo nếu bạn phát hiện tin đăng này là giả mạo, yêu cầu chuyển khoản đặt cọc giữ chỗ đáng ngờ trước khi xem phòng, hoặc có dấu hiệu chiếm đoạt tài sản.',
    'FakePrice': 'Báo cáo nếu giá thuê thực tế khi liên hệ hoặc đến xem nhà cao hơn nhiều so với giá hiển thị trên website.',
    'FakeInfo': 'Báo cáo nếu hình ảnh phòng trọ không đúng thực tế, sai lệch vị trí nghiêm trọng hoặc toà nhà không tồn tại.',
    'Other': 'Báo cáo nếu vi phạm các quy tắc khác như thái độ chủ nhà không phù hợp, tin đăng trùng lặp hoặc chứa nội dung rác.'
  };

  chips.forEach(chip => {
    chip.addEventListener('click', function() {
      chips.forEach(c => c.classList.remove('active'));
      this.classList.add('active');
      const val = this.getAttribute('data-reason');
      if (reasonInput) reasonInput.value = val;
      
      if (reasonHelp) {
        reasonHelp.textContent = helpTexts[val] || '';
        reasonHelp.classList.remove('d-none');
      }
      
      validateReportForm();
    });
  });

  if (descInput) {
    descInput.addEventListener('input', function() {
      const len = this.value.length;
      if (charCount) charCount.textContent = `${len}/500 ký tự`;
      
      if (descWarning) {
        if (len < 10) {
          descWarning.textContent = 'Nhập tối thiểu 10 ký tự';
          descWarning.classList.remove('text-success');
          descWarning.classList.add('text-danger');
        } else {
          descWarning.textContent = 'Nội dung hợp lệ';
          descWarning.classList.remove('text-danger');
          descWarning.classList.add('text-success');
        }
      }
      
      validateReportForm();
    });
  }

  function validateReportForm() {
    const isReasonSelected = reasonInput && reasonInput.value !== '';
    const isDescValid = descInput && descInput.value.length >= 10 && descInput.value.length <= 500;
    
    if (submitBtn) {
      submitBtn.disabled = !(isReasonSelected && isDescValid);
    }
  }
});
</script>
}

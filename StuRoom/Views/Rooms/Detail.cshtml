@model StuRoom.Models.ViewModels.RoomPublicDetailViewModel
@using StuRoom.Models
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = $"Phòng {Model.Room.RoomNumber} — {Model.Room.Building.Name}";
    Layout = "_Layout";

    var categoryLabel = new Dictionary<FeeCategory, (string name, string icon)>
    {
        [FeeCategory.Rent]        = ("Tiền thuê",  "bi-house"),
        [FeeCategory.Electricity] = ("Điện",        "bi-lightning-charge"),
        [FeeCategory.Water]       = ("Nước",         "bi-droplet"),
        [FeeCategory.Internet]    = ("Internet",     "bi-wifi"),
        [FeeCategory.Parking]     = ("Đỗ xe",        "bi-car-front"),
        [FeeCategory.Other]       = ("Khác",         "bi-three-dots"),
    };
}

<div class="container py-5">
@* Hidden antiforgery token for AJAX *@
@Html.AntiForgeryToken()
  
  @* Breadcrumb *@
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb small px-3 py-2 bg-white rounded-pill shadow-sm d-inline-flex border">
      <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-primary fw-semibold"><i class="bi bi-house me-1"></i>Tìm phòng</a></li>
      <li class="breadcrumb-item active text-secondary" aria-current="page">@Model.Room.Building.Name — Phòng @Model.Room.RoomNumber</li>
    </ol>
  </nav>

  <div class="row g-4">

    @* ══════ Cột chính (Trái) ══════ *@
    <div class="col-lg-8">

      @* Image carousel *@
      @if (Model.Images.Any())
      {
        <div id="roomCarousel" class="carousel slide rounded-4 overflow-hidden shadow-sm mb-4 position-relative"
             data-bs-ride="false">
          <div class="carousel-inner">
            @for (int i = 0; i < Model.Images.Count; i++)
            {
              <div class="carousel-item @(i == 0 ? "active" : "")">
                <img src="@Model.Images[i].ImageUrl"
                     class="d-block w-100"
                     alt="Ảnh phòng @(i+1)"
                     style="height:450px;object-fit:cover" />
              </div>
            }
          </div>
          @if (Model.Images.Count > 1)
          {
            <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon-custom"><i class="bi bi-chevron-left"></i></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon-custom"><i class="bi bi-chevron-right"></i></span>
            </button>
            <div class="carousel-indicators-custom">
              @for (int i = 0; i < Model.Images.Count; i++)
              {
                <button type="button" data-bs-target="#roomCarousel" data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        style="width:8px;height:8px;border-radius:50%;border:none;margin:0 4px;transition:background-color 0.2s;"></button>
              }
            </div>
          }
        </div>
      }
      else
      {
        <div class="bg-light rounded-4 d-flex align-items-center justify-content-center mb-4 border"
             style="height:350px">
          <div class="text-center text-muted">
            <i class="bi bi-camera fs-1 d-block mb-2"></i>
            Chưa có hình ảnh phòng trọ
          </div>
        </div>
      }

      @* Thông tin phòng *@
      <div class="card border-0 shadow-sm mb-4 p-3 info-card">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <h3 class="fw-bold mb-0 text-dark">Phòng @Model.Room.RoomNumber</h3>
            @{
              bool isFav = ViewBag.IsFavorite == true;
            }
            <div class="d-flex gap-2">
              @* Compare *@
              <button type="button" class="btn btn-sm btn-compare rounded-pill px-3 py-1.5 fw-semibold d-flex align-items-center gap-1.5 shadow-sm"
                      data-room-id="@Model.Room.Id"
                      onclick="toggleCompareRoom(event, @Model.Room.Id, '@Model.Room.Building.Name.Replace("'", "\\'") - P.@Model.Room.RoomNumber', '@(((Model.RentPrice ?? 0) / 1000000.0m).ToString("0.#")) ' + '@Localizer["Tr/tháng"]', '@Model.Images.FirstOrDefault()?.ImageUrl')">
                <i class="bi bi-shuffle"></i>
                <span class="compare-text small">@Localizer["So sánh"]</span>
              </button>

              @* Favorite *@
              <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1.5 fw-semibold d-flex align-items-center gap-1.5 shadow-sm @(isFav ? "active" : "")"
                      id="detailFavBtn" onclick="toggleDetailFav(@Model.Room.Id)">
                <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                <span id="favText" class="small">@(isFav ? Localizer["Đã lưu"].Value : Localizer["Lưu tin"].Value)</span>
              </button>
            </div>
          </div>
          <div class="text-muted small mb-4">
            <div class="d-flex align-items-center gap-1.5">
              <i class="bi bi-geo-alt-fill text-primary"></i>
              <span>
                @Model.Room.Building.Address
                @if (!string.IsNullOrWhiteSpace(Model.Room.Building.Ward)) { <span>, @Model.Room.Building.Ward</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Room.Building.District)) { <span>, @Model.Room.Building.District</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Room.Building.Province)) { <span>, @Model.Room.Building.Province</span> }
              </span>
            </div>
            <div class="mt-2 ps-3.5">
              @if (Model.Room.Building.Latitude.HasValue && Model.Room.Building.Longitude.HasValue)
              {
                <a href="https://www.google.com/maps/search/?api=1&query=@Model.Room.Building.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.Room.Building.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                   target="_blank" class="btn btn-outline-primary btn-sm rounded-pill py-1 px-2.5 small" style="font-size: 11px; padding: 2px 8px;">
                  <i class="bi bi-map me-1"></i>@Localizer["Xem trên bản đồ"]
                </a>
              }
              else
              {
                var addressQuery = $"{Model.Room.Building.Name}, {Model.Room.Building.Address}, {Model.Room.Building.Ward}, {Model.Room.Building.District}, {Model.Room.Building.Province}";
                <a href="https://www.google.com/maps/search/?api=1&query=@System.Net.WebUtility.UrlEncode(addressQuery)" 
                   target="_blank" class="btn btn-outline-primary btn-sm rounded-pill py-1 px-2.5 small" style="font-size: 11px; padding: 2px 8px;">
                  <i class="bi bi-map me-1"></i>@Localizer["Xem trên bản đồ"]
                </a>
              }
            </div>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
              <div class="spec-box">
                <div class="spec-icon-wrapper"><i class="bi bi-rulers text-primary"></i></div>
                <div class="fw-bold text-dark fs-5 mt-1">@Model.Room.Area m²</div>
                <div class="text-muted small">Diện tích</div>
              </div>
            </div>
            @if (Model.Room.FloorNumber.HasValue)
            {
              <div class="col-6 col-md-3">
                <div class="spec-box">
                  <div class="spec-icon-wrapper"><i class="bi bi-layers text-primary"></i></div>
                  <div class="fw-bold text-dark fs-5 mt-1">Tầng @Model.Room.FloorNumber</div>
                  <div class="text-muted small">Vị trí tầng</div>
                </div>
              </div>
            }
            @if (Model.Room.Capacity.HasValue)
            {
              <div class="col-6 col-md-3">
                <div class="spec-box">
                  <div class="spec-icon-wrapper"><i class="bi bi-people text-primary"></i></div>
                  <div class="fw-bold text-dark fs-5 mt-1">@Model.Room.Capacity người</div>
                  <div class="text-muted small">Sức chứa</div>
                </div>
              </div>
            }
            @if (Model.AvgRating.HasValue)
            {
              <div class="col-6 col-md-3">
                <div class="spec-box">
                  <div class="spec-icon-wrapper"><i class="bi bi-star-fill text-warning"></i></div>
                  <div class="fw-bold text-dark fs-5 mt-1">@Model.AvgRating.Value.ToString("0.0")</div>
                  <div class="text-muted small">@Model.Reviews.Count đánh giá</div>
                </div>
              </div>
            }
          </div>

          @if (!string.IsNullOrWhiteSpace(Model.Room.Description))
          {
            <div class="border-top pt-4">
              <h6 class="fw-bold text-dark mb-2">Mô tả phòng</h6>
              <p class="text-secondary lh-lg mb-0" style="font-size: 14.5px;">@Model.Room.Description</p>
            </div>
          }
        </div>
      </div>

      @* Tiện ích *@
      @if (Model.Amenities.Any())
      {
        <div class="card border-0 shadow-sm mb-4 p-3 info-card">
          <div class="card-body">
            <h6 class="fw-bold mb-4 text-dark"><i class="bi bi-tags-fill text-primary me-2"></i>Tiện ích sẵn có</h6>
            <div class="row g-3">
              @foreach (var a in Model.Amenities)
              {
                <div class="col-6 col-md-4">
                  <div class="d-flex align-items-center gap-2.5">
                    <div class="amenity-icon-wrapper"><i class="bi @a.IconClass"></i></div>
                    <span class="small fw-semibold text-secondary">@a.Name</span>
                  </div>
                </div>
              }
            </div>
          </div>
        </div>
      }

      @* Bảng phí *@
      @if (Model.FeeConfigs.Any())
      {
        <div class="card border-0 shadow-sm mb-4 p-3 info-card">
          <div class="card-body">
            <h6 class="fw-bold mb-4 text-dark"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Chi phí dịch vụ khác</h6>
            <div class="table-responsive rounded-3 border">
              <table class="table table-hover table-flat align-middle mb-0">
                <thead>
                  <tr>
                    <th scope="col" class="ps-3">Loại dịch vụ</th>
                    <th scope="col" class="text-end">Đơn giá</th>
                    <th scope="col" class="ps-4">Cách tính phí</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var f in Model.FeeConfigs)
                  {
                    var (catName, catIcon) = categoryLabel[f.FeeCategory];
                    <tr>
                      <td class="ps-3 fw-semibold text-dark">
                        <i class="bi @catIcon me-2 text-secondary fs-6"></i>
                        @f.Name
                      </td>
                      <td class="text-end fw-bold text-primary">
                        @f.UnitPrice.ToString("N0") ₫<span class="text-muted fw-normal small">/@f.Unit</span>
                      </td>
                      <td class="text-secondary small ps-4">
                        @(f.CalcType == CalcType.Fixed ? "Cố định hàng tháng" : "Theo số đo thực tế")
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      }

      @* Review alerts *@
      @if (TempData["ReviewSuccess"] != null)
      {
        <div class="alert alert-success alert-dismissible fade show rounded-3 py-2.5 small mb-3 border-0 shadow-sm">
          <i class="bi bi-check-circle-fill me-1.5 text-success"></i>@TempData["ReviewSuccess"]
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      }
      @if (TempData["ReviewError"] != null)
      {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 py-2.5 small mb-3 border-0 shadow-sm">
          <i class="bi bi-exclamation-circle-fill me-1.5 text-danger"></i>@TempData["ReviewError"]
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      }

      @* Write review form *@
      @if (Model.CanReview)
      {
        <div class="card border-0 shadow-sm mb-4 p-3 info-card" style="border-left: 4px solid #2563eb !important;">
          <div class="card-body">
            <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Viết đánh giá phòng trọ</h6>
            <form asp-controller="Reviews" asp-action="Create" method="post">
              @Html.AntiForgeryToken()
              <input type="hidden" name="roomId"     value="@Model.Room.Id" />
              <input type="hidden" name="contractId" value="@Model.ReviewContractId" />
              <div class="mb-3">
                <label class="form-label small fw-semibold text-secondary">Số sao đánh giá <span class="text-danger">*</span></label>
                <div class="d-flex gap-2 star-picker" id="starPicker">
                  @for (int s = 1; s <= 5; s++)
                  {
                    <i class="bi bi-star fs-3 star-btn" data-val="@s"
                       style="cursor:pointer;color:#cbd5e1;transition:color 0.15s, transform 0.15s;" title="@s sao"></i>
                  }
                </div>
                <input type="hidden" name="rating" id="ratingInput" required />
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold text-secondary">Nhận xét chi tiết</label>
                <textarea name="content" class="form-control form-control-custom" rows="3"
                          placeholder="Chia sẻ trải nghiệm thực tế về phòng trọ này..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary rounded-pill px-4 btn-sm fw-semibold shadow-sm">
                <i class="bi bi-send-fill me-1.5"></i>Gửi đánh giá
              </button>
            </form>
          </div>
        </div>
      }

      @* Reviews *@
      <div class="card border-0 shadow-sm mb-4 p-3 info-card">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between mb-4">
            <h6 class="fw-bold mb-0 text-dark">
              <i class="bi bi-chat-left-text-fill text-primary me-2"></i>Đánh giá từ khách thuê
              @if (Model.Reviews.Any())
              {
                <span class="text-muted fw-normal small ms-1">(@Model.Reviews.Count)</span>
              }
            </h6>
            @if (Model.AvgRating.HasValue)
            {
              <div class="d-flex align-items-center gap-1">
                @for (int i = 1; i <= 5; i++)
                {
                  <i class="bi @(i <= Math.Round(Model.AvgRating.Value) ? "bi-star-fill text-warning" : "bi-star text-muted")"
                     style="font-size: 14px;"></i>
                }
                <span class="fw-bold text-dark ms-1">@Model.AvgRating.Value.ToString("0.0")</span>
              </div>
            }
          </div>

          @if (!Model.Reviews.Any())
          {
            <div class="text-center py-4 text-muted small">
              <i class="bi bi-chat-square-dots fs-3 d-block mb-2"></i>
              Chưa có đánh giá nào cho phòng trọ này.
            </div>
          }
          else
          {
            <div class="d-flex flex-column gap-4">
              @foreach (var rv in Model.Reviews)
              {
                <div class="border-bottom pb-4 last-border-none">
                  <div class="d-flex align-items-center gap-2.5 mb-2">
                    @if (!string.IsNullOrWhiteSpace(rv.Reviewer.AvatarUrl))
                    {
                      <img src="@rv.Reviewer.AvatarUrl" class="rounded-circle border"
                           style="width:36px;height:36px;object-fit:cover" alt="avatar" />
                    }
                    else
                    {
                      <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center fw-bold"
                           style="width:36px;height:36px;font-size:14px;color:#2563eb">
                        @rv.Reviewer.FullName.FirstOrDefault()
                      </div>
                    }
                    <div>
                      <div class="fw-bold text-dark small">@rv.Reviewer.FullName</div>
                      <div class="text-muted" style="font-size:11px">@rv.CreatedAt.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="ms-auto bg-light rounded-pill px-2.5 py-1 d-flex gap-0.5 border">
                      @for (int i = 1; i <= 5; i++)
                      {
                        <i class="bi @(i <= rv.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"
                           style="font-size:11px;"></i>
                      }
                    </div>
                  </div>
                  @if (!string.IsNullOrWhiteSpace(rv.Content))
                  {
                    <p class="mb-0 text-secondary small lh-base ps-1">@rv.Content</p>
                  }
                </div>
              }
            </div>
          }
        </div>
      </div>

    </div>

    @* ══════ Sidebar CTA (Phải - Sticky) ══════ *@
    <div class="col-lg-4">
      <div class="card border-0 shadow sticky-top cta-sidebar" style="top:90px; z-index: 100;">
        <div class="card-body p-4">

          @* Price *@
          @if (Model.RentPrice.HasValue)
          {
            <div class="mb-4 pb-3 border-bottom">
              <span class="text-muted small text-uppercase fw-semibold d-block" style="font-size: 10px; letter-spacing: 0.05em; margin-bottom: 4px;">Giá thuê phòng</span>
              <div class="d-flex align-items-baseline gap-1 mb-0" style="line-height: 1;">
                <span style="font-size: 2.2rem; font-weight: 800; color: var(--link-color); font-family: 'Outfit', sans-serif; letter-spacing: -0.02em;">@Model.RentPrice.Value.ToString("N0")</span>
                <span style="font-size: 1.15rem; font-weight: 700; color: var(--link-color); font-family: 'Outfit', sans-serif;">₫</span><span style="font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); margin-left: 2px;">/@Model.RentUnit</span>
              </div>
            </div>
          }

          @* Building info *@
          <div class="mb-4 text-muted">
            <div class="fw-bold text-dark mb-2">@Model.Room.Building.Name</div>
            <div class="small d-flex align-items-start gap-1.5"><i class="bi bi-geo-alt-fill text-primary mt-0.5"></i><span>@Model.Room.Building.Address</span></div>
            @if (!string.IsNullOrWhiteSpace(Model.Room.Building.District))
            {
              <div class="small text-secondary ms-4 mt-1">@Model.Room.Building.District, @Model.Room.Building.Province</div>
            }
          </div>

          @* Landlord Contact info *@
          @if (Model.Room.Building.Landlord != null)
          {
            <div class="mb-4 pt-3 border-top text-muted">
              <span class="text-muted small text-uppercase fw-semibold d-block" style="font-size: 10px; letter-spacing: 0.05em; margin-bottom: 8px;">Thông tin liên hệ</span>
              <div class="d-flex align-items-center gap-2.5 mb-3">
                <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center text-primary rounded-circle" style="width: 32px; height: 32px; flex-shrink: 0;">
                  <i class="bi bi-person-fill"></i>
                </div>
                <div>
                  <div class="fw-semibold text-dark small" style="font-size: 13.5px;">@Model.Room.Building.Landlord.FullName</div>
                  <div class="text-muted" style="font-size: 11.5px;">Chủ trọ</div>
                </div>
              </div>
              
              <div class="small d-flex align-items-center gap-2 text-secondary mb-1.5" style="font-size: 13px;">
                <i class="bi bi-telephone text-primary"></i>
                <a href="tel:@Model.Room.Building.Landlord.PhoneNumber" class="text-decoration-none text-secondary hover-text-primary">
                  @(string.IsNullOrWhiteSpace(Model.Room.Building.Landlord.PhoneNumber) ? "Chưa cập nhật SĐT" : Model.Room.Building.Landlord.PhoneNumber)
                </a>
              </div>
              
              <div class="small d-flex align-items-center gap-2 text-secondary" style="font-size: 13px;">
                <i class="bi bi-envelope text-primary"></i>
                <a href="mailto:@Model.Room.Building.Landlord.Email" class="text-decoration-none text-secondary hover-text-primary">
                  @Model.Room.Building.Landlord.Email
                </a>
              </div>
            </div>
          }

          @* CTA buttons *@
          @if (Model.CanBook)
          {
            <div class="d-grid gap-3">
              <a asp-controller="ViewingRequests" asp-action="Create"
                 asp-route-roomId="@Model.Room.Id"
                 class="btn btn-booking-outline py-2.5 fw-bold d-flex align-items-center justify-content-center shadow-sm">
                <i class="bi bi-calendar-check-fill me-2"></i>Đặt lịch xem phòng
              </a>
              <a asp-controller="BookingRequests" asp-action="Create"
                 asp-route-roomId="@Model.Room.Id"
                 class="btn btn-booking-primary py-2.5 fw-bold d-flex align-items-center justify-content-center shadow-sm">
                <i class="bi bi-bookmark-check-fill me-2"></i>Đặt phòng ngay
              </a>
            </div>
          }
          else if (!User.Identity!.IsAuthenticated)
          {
            <div class="d-grid gap-3">
              <a asp-area="Identity" asp-page="/Account/Login"
                 asp-route-returnUrl="@Context.Request.Path"
                 class="btn btn-booking-primary py-2.5 fw-bold d-flex align-items-center justify-content-center shadow-sm">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập để đặt phòng
              </a>
            </div>
            <p class="text-muted small text-center mt-3 mb-0">
              Chưa có tài khoản?
              <a asp-area="Identity" asp-page="/Account/Register" class="text-primary fw-semibold text-decoration-none">Đăng ký ngay</a>
            </p>
          }
          else
          {
            <div class="alert alert-info small py-2.5 px-3 rounded-3 border-0 mb-0 shadow-sm d-flex align-items-start gap-2">
              <i class="bi bi-info-circle-fill text-info mt-0.5"></i>
              <span>Chỉ tài khoản có quyền <strong>Khách thuê (Tenant)</strong> mới có thể thực hiện đặt phòng.</span>
            </div>
          }

          @* Report listing button *@
          <div class="d-grid mt-3 pt-3 border-top">
            <button type="button" class="btn btn-outline-warning btn-sm rounded-pill d-flex align-items-center justify-content-center gap-1.5 text-warning"
                    data-bs-toggle="modal" data-bs-target="#reportRoomModal">
              <i class="bi bi-exclamation-triangle"></i>
              @Localizer["Báo cáo vi phạm"]
            </button>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>

@* ── Modal: Báo cáo vi phạm ── *@
<div class="modal fade" id="reportRoomModal" tabindex="-1" aria-labelledby="reportRoomModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
      <form asp-action="ReportRoom" asp-controller="Rooms" method="post" id="reportRoomForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="roomId" value="@Model.Room.Id" />
        <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
          <h5 class="modal-title fw-bold text-dark" id="reportRoomModalLabel" style="font-family: 'Outfit', sans-serif;"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>@Localizer["Báo cáo vi phạm"]</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-dark px-4 py-3">
          @if (!User.Identity!.IsAuthenticated)
          {
            <div class="text-center py-4">
              <i class="bi bi-shield-lock text-muted fs-1 mb-2 d-block"></i>
              <p class="text-muted mb-3">@Localizer["Bạn cần đăng nhập để thực hiện báo cáo vi phạm."]</p>
              <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary rounded-pill btn-sm px-4 fw-semibold shadow-sm">@Localizer["Đăng nhập ngay"]</a>
            </div>
          }
          else
          {
            <div class="mb-3 text-start">
              <label class="form-label fw-bold small text-secondary mb-2">@Localizer["Chọn lý do vi phạm"] <span class="text-danger">*</span></label>
              
              <input type="hidden" name="reason" id="reportReasonInput" required />
              
              <div class="report-reason-container">
                <div class="report-reason-chip" data-reason="Fraud" title="@Localizer["Lừa đảo, đặt cọc ảo"]">
                  <i class="bi bi-shield-slash-fill text-warning chip-icon"></i>
                  <span class="chip-label">@Localizer["Lừa đảo, đặt cọc ảo"]</span>
                  <i class="bi bi-check-circle-fill chip-check"></i>
                </div>
                <div class="report-reason-chip" data-reason="FakePrice" title="@Localizer["Giá thuê không đúng thực tế"]">
                  <i class="bi bi-cash-coin text-success chip-icon"></i>
                  <span class="chip-label">@Localizer["Giá không đúng thực tế"]</span>
                  <i class="bi bi-check-circle-fill chip-check"></i>
                </div>
                <div class="report-reason-chip" data-reason="FakeInfo" title="@Localizer["Thông tin/Hình ảnh sai sự thật"]">
                  <i class="bi bi-image-fill text-primary chip-icon"></i>
                  <span class="chip-label">@Localizer["Thông tin sai sự thật"]</span>
                  <i class="bi bi-check-circle-fill chip-check"></i>
                </div>
                <div class="report-reason-chip" data-reason="Other" title="@Localizer["Lý do khác"]">
                  <i class="bi bi-three-dots text-secondary chip-icon"></i>
                  <span class="chip-label">@Localizer["Lý do vi phạm khác"]</span>
                  <i class="bi bi-check-circle-fill chip-check"></i>
                </div>
              </div>
              
              <div id="reasonHelpText" class="alert alert-secondary py-2 px-3 small rounded-3 border-0 d-none mb-3" style="font-size: 11.5px; background: rgba(79, 70, 229, 0.03); color: var(--text-color);"></div>
            </div>
            
            <div class="mb-3 text-start">
              <label class="form-label fw-bold small text-secondary">@Localizer["Chi tiết vi phạm"] <span class="text-danger">*</span></label>
              <textarea name="description" id="reportDescInput" class="form-control form-control-custom" rows="4" 
                        maxlength="500" placeholder="@Localizer["Cung cấp thêm thông tin chi tiết về hành vi vi phạm..."]" required></textarea>
              <div class="d-flex justify-content-between text-muted mt-1.5" style="font-size: 11px;">
                <span id="reportDescWarning" class="text-danger fw-semibold">Nhập tối thiểu 10 ký tự</span>
                <span id="reportCharCount">0/500 ký tự</span>
              </div>
            </div>
          }
        </div>
        <div class="modal-footer border-top-0 px-4 pb-4 pt-0">
          <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3.5 py-1.5 fw-semibold" data-bs-dismiss="modal">@Localizer["Huỷ"]</button>
          @if (User.Identity.IsAuthenticated)
          {
            <button type="submit" id="btnSubmitReport" class="btn btn-danger btn-sm rounded-pill px-4 py-1.5 fw-semibold shadow-sm" disabled>
              <i class="bi bi-send-fill me-1.5"></i>@Localizer["Gửi báo cáo"]
            </button>
          }
        </div>
      </form>
    </div>
  </div>
</div>


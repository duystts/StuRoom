@model StuRoom.Models.Invoice
@using StuRoom.Models
@{
    ViewData["Title"] = $"Hóa đơn #{Model.Id}";

    var totalPaid = Model.Payments.Where(p => p.Amount > 0).Sum(p => p.Amount);
    var remaining = Model.TotalAmount - totalPaid;
    var isUnpaid = Model.Status == InvoiceStatus.Sent || Model.Status == InvoiceStatus.Overdue;

    var statusCss = Model.Status switch
    {
        InvoiceStatus.Paid      => "bg-success text-white border-0",
        InvoiceStatus.Sent      => "bg-warning text-dark border-0",
        InvoiceStatus.Overdue   => "bg-danger text-white border-0",
        InvoiceStatus.Cancelled => "bg-secondary text-white border-0",
        _                       => "bg-light text-dark"
    };

    var statusLabel = Model.Status switch
    {
        InvoiceStatus.Paid      => "Đã thanh toán",
        InvoiceStatus.Sent      => "Chờ thanh toán",
        InvoiceStatus.Overdue   => "Trễ hạn đóng tiền",
        InvoiceStatus.Cancelled => "Đã hủy bỏ",
        _                       => "Nháp"
    };

    var methodMap = new Dictionary<PaymentMethod, string>
    {
        [PaymentMethod.Cash]         = "Tiền mặt (Đóng trực tiếp)",
        [PaymentMethod.BankTransfer] = "Chuyển khoản Ngân hàng",
        [PaymentMethod.MoMo]         = "Ví điện tử MoMo",
        [PaymentMethod.VNPay]        = "Cổng thanh toán VNPay"
    };
}

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb small">
    <li class="breadcrumb-item"><a asp-action="Index">Phòng đang thuê</a></li>
    <li class="breadcrumb-item"><a asp-action="ContractDetail" asp-route-id="@Model.ContractId">Hợp đồng #@Model.ContractId</a></li>
    <li class="breadcrumb-item active">Hóa đơn tháng @Model.BillingMonth/@Model.BillingYear</li>
  </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
  <div>
    <h4 class="fw-bold mb-0">
      Chi tiết hóa đơn tháng @Model.BillingMonth/@Model.BillingYear
      <span class="badge @statusCss ms-2 fs-6 px-3 py-2 rounded-pill shadow-sm">@statusLabel</span>
    </h4>
    <p class="text-muted small mb-0">
      Phòng @Model.Contract.Room.RoomNumber — @Model.Contract.Room.Building.Name — Mã HĐ #@Model.ContractId
    </p>
  </div>
  @if (isUnpaid && remaining > 0)
  {
    <button class="btn btn-success rounded-pill px-4 py-2 font-bold shadow-sm d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#payModal">
      <i class="bi bi-credit-card-2-front-fill fs-5"></i>Thanh toán ngay
    </button>
  }
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show py-2 small border-0 shadow-sm rounded-3 mb-4">
    <i class="bi bi-check-circle-fill me-2 text-success"></i>@Html.Raw(TempData["Success"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show py-2 small border-0 shadow-sm rounded-3 mb-4">
    <i class="bi bi-exclamation-circle-fill me-2 text-danger"></i>@Html.Raw(TempData["Error"])
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="row g-4">
  @* ── Cột trái: Chi tiết phí ── *@
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-4 text-dark"><i class="bi bi-list-task me-2 text-primary"></i>Danh mục dịch vụ và tiền phòng</h6>
        <div class="table-responsive">
          <table class="table align-middle table-hover">
            <thead>
              <tr class="text-secondary small border-bottom">
                <th style="min-width: 180px;">Mô tả dịch vụ</th>
                <th>Chỉ số đầu</th>
                <th>Chỉ số cuối</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th class="text-end">Thành tiền</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var item in Model.Items)
              {
                <tr>
                  <td class="small fw-semibold py-3">@item.Description</td>
                  <td class="small text-muted">@(item.PreviousReading.HasValue ? item.PreviousReading.Value.ToString("N0") : "—")</td>
                  <td class="small text-muted">@(item.CurrentReading.HasValue ? item.CurrentReading.Value.ToString("N0") : "—")</td>
                  <td class="small">@(item.Quantity.HasValue ? item.Quantity.Value.ToString("N1") : "1")</td>
                  <td class="small text-muted">@item.UnitPrice.ToString("N0") ₫</td>
                  <td class="small fw-bold text-dark text-end">@item.Amount.ToString("N0") ₫</td>
                </tr>
              }
              <tr class="border-top-0">
                <td colspan="5" class="text-end py-3 fw-semibold text-muted small">Tổng cộng cần thanh toán:</td>
                <td class="text-end py-3 fw-bold text-primary" style="font-size: 18px;">@Model.TotalAmount.ToString("N0") ₫</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    @* Ghi chú hóa đơn *@
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-chat-right-quote-fill me-2 text-primary"></i>Ghi chú từ chủ trọ</h6>
          <p class="text-secondary small mb-0 italic">@Model.Notes</p>
        </div>
      </div>
    }

    @* Lịch sử giao dịch đóng tiền *@
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử giao dịch thanh toán</h6>
        @if (!Model.Payments.Any())
        {
          <div class="text-center py-4 text-muted small">
            <i class="bi bi-cash-stack fs-3 d-block mb-1 text-secondary opacity-50"></i>
            Chưa ghi nhận giao dịch thanh toán nào cho hóa đơn này.
          </div>
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr class="text-secondary small">
                  <th>Ngày đóng</th>
                  <th>Số tiền</th>
                  <th>Phương thức</th>
                  <th>Mã giao dịch</th>
                  <th>Ghi chú</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var p in Model.Payments.OrderByDescending(x => x.PaymentDate))
                {
                  <tr>
                    <td class="small">@p.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="small fw-bold text-success">@p.Amount.ToString("N0") ₫</td>
                    <td class="small">@methodMap[p.Method]</td>
                    <td class="small fw-semibold text-secondary">@p.TransactionRef</td>
                    <td class="small text-muted italic">@p.Notes</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  </div>

  @* ── Cột phải: Tóm tắt nợ & Hạn thu ── *@
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm rounded-4 bg-gradient-light mb-4">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3 text-dark">Tóm tắt hóa đơn</h6>
        <div class="d-flex justify-content-between mb-2 small">
          <span class="text-muted">Hạn đóng tiền:</span>
          <span class="fw-semibold text-danger">@Model.DueDate.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="d-flex justify-content-between mb-2 small">
          <span class="text-muted">Tổng tiền hóa đơn:</span>
          <span class="fw-semibold text-dark">@Model.TotalAmount.ToString("N0") ₫</span>
        </div>
        <div class="d-flex justify-content-between mb-2 small">
          <span class="text-muted">Đã thanh toán:</span>
          <span class="fw-semibold text-success">@totalPaid.ToString("N0") ₫</span>
        </div>
        <hr class="my-2" />
        <div class="d-flex justify-content-between align-items-center">
          <span class="fw-bold text-dark" style="font-size: 14px;">Còn lại cần nộp:</span>
          <span class="fw-bold text-primary" style="font-size: 20px;">@remaining.ToString("N0") ₫</span>
        </div>
      </div>
    </div>

    @* Gợi ý liên hệ *@
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 text-center">
        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
          <i class="bi bi-question-circle text-primary fs-4"></i>
        </div>
        <h6 class="fw-bold text-dark">Thắc mắc về hóa đơn?</h6>
        <p class="text-muted small">Nếu phát hiện sai sót về chỉ số điện/nước hoặc số tiền, vui lòng liên hệ trực tiếp chủ trọ để được điều chỉnh kịp thời.</p>
        <a href="tel:@Model.Contract.Room.Building.Landlord.PhoneNumber" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold">
          <i class="bi bi-telephone-fill me-1"></i>Gọi cho Chủ trọ
        </a>
      </div>
    </div>
  </div>
</div>

@* Modal: Mô phỏng cổng Thanh toán *@
@if (isUnpaid && remaining > 0)
{
  <div class="modal fade" id="payModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content border-0 rounded-4 shadow">
        <form asp-action="PayInvoice" asp-route-id="@Model.Id" method="post">
          @Html.AntiForgeryToken()
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold text-dark">Mô phỏng thanh toán trực tuyến</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body py-4">
            <div class="alert alert-info py-2 small border-0 bg-info-subtle mb-3">
              <i class="bi bi-info-circle-fill text-info me-2"></i>
              Đây là hệ thống **mô phỏng thanh toán**. Số tiền cần đóng sẽ được đánh dấu đã đóng trên hệ thống ngay khi xác nhận.
            </div>
            
            <div class="bg-light p-3 rounded-3 mb-4">
              <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Số tiền thanh toán:</span>
                <span class="fw-bold text-primary fs-5">@remaining.ToString("N0") ₫</span>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold text-dark small">Chọn cổng thanh toán</label>
              <div class="d-flex flex-column gap-2">
                <label class="d-flex align-items-center gap-3 p-3 border rounded-3 cursor-pointer hover-border-primary" style="cursor: pointer;">
                  <input type="radio" name="method" value="@PaymentMethod.MoMo" checked />
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-danger rounded p-1 text-white fw-bold" style="font-size: 10px;">MoMo</span>
                    <span class="small fw-semibold">Thanh toán qua ví điện tử MoMo</span>
                  </div>
                </label>
                <label class="d-flex align-items-center gap-3 p-3 border rounded-3 cursor-pointer hover-border-primary" style="cursor: pointer;">
                  <input type="radio" name="method" value="@PaymentMethod.VNPay" />
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary rounded p-1 text-white fw-bold" style="font-size: 10px;">VNPay</span>
                    <span class="small fw-semibold">Thanh toán qua cổng VNPay (Atm/Qr-code)</span>
                  </div>
                </label>
                <label class="d-flex align-items-center gap-3 p-3 border rounded-3 cursor-pointer hover-border-primary" style="cursor: pointer;">
                  <input type="radio" name="method" value="@PaymentMethod.BankTransfer" />
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-dark rounded p-1 text-white fw-bold" style="font-size: 10px;">Bank</span>
                    <span class="small fw-semibold">Chuyển khoản Ngân hàng (App Banking)</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold text-dark small">Ghi chú thanh toán (tùy chọn)</label>
              <textarea name="notes" class="form-control form-control-sm rounded-3" rows="2" placeholder="Nhập ghi chú cho chủ trọ..."></textarea>
            </div>
          </div>
          <div class="modal-footer border-0 pt-0">
            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Đóng</button>
            <button type="submit" class="btn btn-sm btn-success rounded-pill px-4 fw-bold">
              Xác nhận & Thanh toán
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
}

<style>
  .hover-border-primary:hover {
    border-color: #0d6efd !important;
    background-color: #f8f9fa;
  }
</style>

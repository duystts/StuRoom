@model List<StuRoom.Models.Contract>
@using StuRoom.Models
@{
    ViewData["Title"] = "Phòng đang thuê";

    var statusMap = new Dictionary<ContractStatus, (string label, string css, string icon)>
    {
        [ContractStatus.Pending]    = ("Chờ kích hoạt", "bg-warning-subtle text-warning border border-warning-subtle", "bi-hourglass-split"),
        [ContractStatus.Active]     = ("Đang thuê",     "bg-success-subtle text-success border border-success-subtle", "bi-house-heart-fill"),
        [ContractStatus.Expired]    = ("Hết hạn",       "bg-secondary-subtle text-secondary border border-secondary-subtle", "bi-calendar-x"),
        [ContractStatus.Terminated] = ("Đã chấm dứt",   "bg-danger-subtle text-danger border border-danger-subtle", "bi-file-earmark-x-fill"),
    };
}

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="fw-bold mb-0 text-gradient-primary">Phòng đang thuê của tôi</h4>
      <p class="text-muted small mb-0">Theo dõi thông tin phòng trọ, hợp đồng và lịch sử hóa đơn thanh toán</p>
    </div>
    <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary rounded-pill btn-sm px-3 shadow-sm">
      <i class="bi bi-search me-1"></i>Tìm phòng mới
    </a>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show py-2 small border-0 shadow-sm rounded-3 mb-3">
      <i class="bi bi-check-circle-fill me-2 text-success"></i>@TempData["Success"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show py-2 small border-0 shadow-sm rounded-3 mb-3">
      <i class="bi bi-exclamation-circle-fill me-2 text-danger"></i>@TempData["Error"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  @if (!Model.Any())
  {
    <div class="card border-0 shadow-sm rounded-4 text-center py-5 px-4 my-4">
      <div class="card-body">
        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-house-dash-fill fs-1 text-secondary"></i>
        </div>
        <h5 class="fw-bold text-dark">Bạn chưa có phòng đang thuê</h5>
        <p class="text-muted mx-auto" style="max-width: 420px;">
          Sau khi gửi yêu cầu đặt phòng và được chủ trọ duyệt và tạo hợp đồng, thông tin phòng đang thuê của bạn sẽ xuất hiện tại đây.
        </p>
        <div class="mt-4">
          <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-bold">
            Tìm phòng trọ ngay
          </a>
        </div>
      </div>
    </div>
  }
  else
  {
    <div class="row g-4">
      @foreach (var c in Model)
      {
        var (lbl, css, icon) = statusMap[c.Status];
        var img = c.Room.Images?.FirstOrDefault(i => i.IsPrimary)
               ?? c.Room.Images?.OrderBy(i => i.SortOrder).FirstOrDefault();
        var isCurrentActive = c.Status == ContractStatus.Active;

        <div class="col-md-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden card-hover-transition @(isCurrentActive ? "border-start border-4 border-success" : "")">
            
            @* Trạng thái nổi góc *@
            <div class="position-absolute top-0 end-0 m-3 z-1">
              <span class="badge @css px-2 py-1 rounded-pill small d-flex align-items-center gap-1 shadow-sm" style="font-size:11px">
                <i class="bi @icon"></i>@lbl
              </span>
            </div>

            @* Room Image/Placeholder *@
            @if (img != null)
            {
              <img src="@img.ImageUrl" class="card-img-top" style="height:180px;object-fit:cover" alt="Phòng @c.Room.RoomNumber" />
            }
            else
            {
              <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height:180px">
                <div class="text-center">
                  <i class="bi bi-door-open fs-1 text-secondary opacity-50"></i>
                  <div class="small mt-1 text-muted">Không có ảnh</div>
                </div>
              </div>
            }

            <div class="card-body d-flex flex-column p-4">
              <h5 class="fw-bold text-dark mb-1">Phòng @c.Room.RoomNumber</h5>
              <p class="text-muted small mb-3 text-truncate"><i class="bi bi-geo-alt me-1"></i>@c.Room.Building.Name — @c.Room.Building.Province</p>

              <div class="bg-light rounded-3 p-3 mb-3 small flex-grow-1">
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted"><i class="bi bi-calendar-event me-1"></i>Thời hạn thuê:</span>
                  <span class="fw-semibold text-dark">
                    @c.StartDate.ToString("dd/MM/yyyy") - @(c.EndDate.HasValue ? c.EndDate.Value.ToString("dd/MM/yyyy") : "Không thời hạn")
                  </span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted"><i class="bi bi-wallet2 me-1"></i>Giá thuê:</span>
                  <span class="fw-bold text-primary">@c.MonthlyRent.ToString("N0") ₫/tháng</span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted"><i class="bi bi-shield-check me-1"></i>Tiền cọc:</span>
                  <span class="fw-semibold text-dark">@c.DepositAmount.ToString("N0") ₫</span>
                </div>
              </div>

              <div class="d-flex align-items-center justify-content-between pt-2 border-top mt-auto">
                <div class="small">
                  @if (c.TenantId == User.Identity?.Name || c.Tenant.UserName == User.Identity?.Name || c.Tenant.Email == User.Identity?.Name)
                  {
                    <span class="text-secondary fw-semibold"><i class="bi bi-person-badge-fill me-1"></i>Người thuê chính</span>
                  }
                  else
                  {
                    <span class="text-info fw-semibold"><i class="bi bi-people-fill me-1"></i>Thành viên ở ghép</span>
                  }
                </div>
                <a asp-action="ContractDetail" asp-route-id="@c.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">
                  Chi tiết <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>

            </div>
          </div>
        </div>
      }
    </div>
  }
</div>

<style>
  .card-hover-transition {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card-hover-transition:hover {
    transform: translateY(-5px);
    box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1) !important;
  }
  .text-gradient-primary {
    background: linear-gradient(135deg, #0d6efd, #0dcaf0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>

@{
    ViewData["Title"] = "Chờ duyệt tài khoản";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="text-center" style="max-width: 480px;">
        <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" fill="none" viewBox="0 0 24 24"
                 stroke="#f59e0b" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
        </div>
        <h2 class="fw-semibold mb-2">Tài khoản đang chờ duyệt</h2>
        <p class="text-muted mb-4">
            Tài khoản chủ trọ của bạn đã được tạo thành công.<br>
            Vui lòng chờ Admin xem xét và phê duyệt — thường trong vòng <strong>1–2 ngày làm việc</strong>.
        </p>
        <p class="text-muted small mb-4">
            Sau khi được duyệt bạn sẽ có thể đăng phòng, quản lý hợp đồng và hoá đơn.
        </p>
        <div class="d-flex gap-2 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                Về trang chủ
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="/" method="post" class="d-inline">
                <button type="submit" class="btn btn-warning text-white">Đăng xuất</button>
            </form>
        </div>
    </div>
</div>
